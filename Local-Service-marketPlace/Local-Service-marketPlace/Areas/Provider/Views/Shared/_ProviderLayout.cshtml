@using Microsoft.AspNetCore.Identity
@using Local_Service_marketPlace.Data
@using Microsoft.EntityFrameworkCore
@inject SignInManager<Local_Service_marketPlace.Models.ApplicationUser> SignInManager
@inject UserManager<Local_Service_marketPlace.Models.ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

@{
    var currentUserId = UserManager.GetUserId(User);
    var unreadCount = await DbContext.Notifications
        .CountAsync(n => n.UserId == currentUserId && !n.IsRead);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Khidmati Provider</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/khidmati-theme.css" asp-append-version="true" />
</head>
<body class="app-shell provider-shell">
    <nav class="app-navbar">
        <div class="container app-nav-container">
            <div class="d-flex align-items-center gap-2">
                <a asp-area="Provider" asp-controller="Dashboard" asp-action="Index" class="brand-mark">Khid<span>mati</span></a>
                <span class="provider-badge">Provider</span>
            </div>

            <div class="app-nav-links">
                <a asp-area="Provider" asp-controller="Dashboard" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
                   title="Dashboard">
                    <i class="fas fa-tachometer-alt"></i> <span class="nav-label">Dashboard</span>
                </a>
                <a asp-area="Provider" asp-controller="ServiceRequest" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequest" ? "active" : "")"
                   title="Browse Requests">
                    <i class="fas fa-search"></i> <span class="nav-label">Browse</span>
                </a>
                <a asp-area="Provider" asp-controller="Offer" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Offer" ? "active" : "")"
                   title="My Offers">
                    <i class="fas fa-file-alt"></i> <span class="nav-label">Offers</span>
                </a>
                <a asp-area="Provider" asp-controller="Booking" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active" : "")"
                   title="My Bookings">
                    <i class="fas fa-calendar-check"></i> <span class="nav-label">Bookings</span>
                </a>
                <a asp-area="Provider" asp-controller="Wallet" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Wallet" ? "active" : "")"
                   title="Wallet">
                    <i class="fas fa-wallet"></i> <span class="nav-label">Wallet</span>
                </a>
                <a asp-area="Provider" asp-controller="Complaint" asp-action="MyComplaints"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Complaint" ? "active" : "")"
                   title="My Complaints">
                    <i class="fas fa-flag"></i> <span class="nav-label">Complaints</span>
                </a>
                <a asp-area="Provider" asp-controller="Profile" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Profile" ? "active" : "")"
                   title="My Profile">
                    <i class="fas fa-user-cog"></i> <span class="nav-label">Profile</span>
                </a>
            </div>

            <div class="app-nav-actions">
                <a asp-area="Provider" asp-controller="Notification" asp-action="Index" class="notif-bell" aria-label="Notifications">
                    <i class="fas fa-bell"></i>
                    @if (unreadCount > 0)
                    {
                        <span class="notif-badge" id="notif-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                    }
                </a>
              
                <a asp-area="" asp-controller="Account" asp-action="Logout" class="btn-logout">
                    <i class="fas fa-sign-out-alt me-1"></i> Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="page-wrapper">
        <div class="container">@RenderBody()</div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>



    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Success"]',
                confirmButtonColor: '#b86048'
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["Error"]',
                confirmButtonColor: '#d33'
            });
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>
            Swal.fire({
                icon: 'info',
                title: 'Info',
                text: '@TempData["Info"]',
                confirmButtonColor: '#4a3729'
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
