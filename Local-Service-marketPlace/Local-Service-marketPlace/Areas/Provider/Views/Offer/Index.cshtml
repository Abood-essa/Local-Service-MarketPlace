@using Local_Service_marketPlace.Models.Enums
@model IEnumerable<Local_Service_marketPlace.Models.ServiceOffer>
@{
    ViewData["Title"] = "My Offers";
    Layout = "~/Areas/Provider/Views/Shared/_ProviderLayout.cshtml";
}

<div class="page-header">
    <h2><i class="fas fa-file-alt text-primary me-2"></i>My Offers</h2>
    <p>Track all offers you've submitted and send final prices to waiting customers.</p>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-file-alt"></i>
        <h5>No offers yet</h5>
        <p>Browse open requests and submit your first offer.</p>
        <a asp-area="Provider" asp-controller="ServiceRequest" asp-action="Index"
           class="btn btn-primary">
            Browse Requests
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var offer in Model)
        {
            var (badgeCss, badgeLabel) = offer.Status switch
            {
                OfferStatus.Pending => ("bg-warning text-dark", "Pending"),
                OfferStatus.FinalPriceSubmitted => ("bg-info text-dark", "Awaiting Customer"),
                OfferStatus.AcceptedByCustomer => ("bg-success", "Accepted"),
                OfferStatus.RejectedByCustomer => ("bg-danger", "Rejected"),
                _ => ("bg-secondary", offer.Status.ToString())
            };

            <div class="col-md-6">
                <div class="k-card h-100 @(offer.Status == OfferStatus.Pending ? "border-start border-warning border-3" : offer.Status == OfferStatus.AcceptedByCustomer ? "border-start border-success border-3" : "")">

                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="fw-700 mb-0">@offer.ServiceRequest?.Title</h6>
                            <small class="text-muted">
                                <i class="fas fa-tag me-1"></i>@offer.ServiceRequest?.Category?.Name
                                &nbsp;·&nbsp;
                                <i class="fas fa-map-marker-alt me-1"></i>@offer.ServiceRequest?.City
                            </small>
                        </div>
                        <span class="badge @badgeCss badge-status">@badgeLabel</span>
                    </div>

                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <div class="bg-light rounded p-2 text-center small">
                                <div class="text-muted">Estimated Range</div>
                                <div class="fw-700 text-primary">
                                    @offer.EstimatedMinPrice JD — @offer.EstimatedMaxPrice JD
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-light rounded p-2 text-center small">
                                <div class="text-muted">Final Price</div>
                                <div class="fw-700 @(offer.FinalPrice.HasValue ? "text-success" : "text-muted")">
                                    @(offer.FinalPrice.HasValue? offer.FinalPrice + " JD" : "Not set yet")
                                </div>
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(offer.Notes))
                    {
                        <p class="small text-muted mb-2">
                            <i class="fas fa-comment me-1"></i>@offer.Notes
                        </p>
                    }

                    <div class="small text-muted mb-3">
                        <i class="fas fa-user me-1"></i>
                        Customer: @offer.ServiceRequest?.Customer?.FirstName
                        @offer.ServiceRequest?.Customer?.LastName
                        &nbsp;·&nbsp;
                        Submitted @offer.CreatedAt.ToString("MMM dd, yyyy")
                    </div>

                    @* Submit final price — only when still Pending *@
                    @if (offer.Status == OfferStatus.Pending)
                    {
                        <div class="border-top pt-3">
                            <p class="small fw-600 mb-2">
                                <i class="fas fa-tag text-warning me-1"></i>
                                Submit your final price after inspecting the job:
                            </p>
                            <form asp-action="SubmitFinalPrice" method="post"
                                  class="d-flex gap-2 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="offerId" value="@offer.Id" />
                                <div class="input-group" style="max-width:200px;">
                                    <input type="number" name="finalPrice" step="0.5" min="1"
                                           class="form-control form-control-sm"
                                           placeholder="Final price" required />
                                    <span class="input-group-text">JD</span>
                                </div>
                                <button type="submit" class="btn btn-sm btn-warning"
                                        onclick="return confirm('Submit this as your final price?')">
                                    <i class="fas fa-paper-plane me-1"></i> Submit
                                </button>
                            </form>
                        </div>
                    }

                    @if (offer.Status == OfferStatus.FinalPriceSubmitted)
                    {
                        <div class="border-top pt-2 mt-1">
                            <p class="small text-info mb-0">
                                <i class="fas fa-hourglass-half me-1"></i>
                                Final price of <strong>@offer.FinalPrice JD</strong> sent.
                                Waiting for customer to accept or reject.
                            </p>
                        </div>
                    }

                    @if (offer.Status == OfferStatus.AcceptedByCustomer)
                    {
                        <div class="border-top pt-2 mt-1">
                            <p class="small text-success mb-0">
                                <i class="fas fa-check-circle me-1"></i>
                                Customer accepted your offer. Check
                                <a asp-area="Provider" asp-controller="Booking" asp-action="Index">My Bookings</a>
                                to manage the job.
                            </p>
                        </div>
                    }

                </div>
            </div>
        }
    </div>
}
