@using Local_Service_marketPlace.Models
@using Local_Service_marketPlace.Models.Enums
@model IEnumerable<Local_Service_marketPlace.Models.ServiceRequest>
@{
    ViewData["Title"] = "Browse Requests";
    Layout = "~/Areas/Provider/Views/Shared/_ProviderLayout.cshtml";

    var profile = ViewBag.Profile as ProviderProfile;
    var categories = ViewBag.Categories as List<Category>;
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="fas fa-search text-primary me-2"></i>Browse Service Requests</h2>
        <p>Open requests matching your service categories.</p>
    </div>
</div>

@if (!profile?.IsVerified == true)
{
    <div class="verified-banner mb-4">
        <i class="fas fa-eye me-2"></i>
        You can browse requests but <strong>cannot submit offers</strong> until your profile is verified by admin.
    </div>
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@* Filters *@
<form method="get" class="k-card mb-4 py-2">
    <div class="row g-2 align-items-center">
        <div class="col-md-5">
            <div class="input-group">
                <span class="input-group-text bg-white border-end-0">
                    <i class="fas fa-map-marker-alt text-muted"></i>
                </span>
                <input type="text" name="city" value="@ViewBag.City"
                       class="form-control border-start-0"
                       placeholder="Filter by city..." />
            </div>
        </div>
        <div class="col-md-4">
            <select name="categoryId" class="form-select">
                <option value="">All My Categories</option>
                @if (categories != null)
                {
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id"
                                selected="@(ViewBag.CategoryId?.ToString() == cat.Id.ToString())">
                            @cat.Name
                        </option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">
                <i class="fas fa-filter me-1"></i> Filter
            </button>
        </div>
        <div class="col-md-1">
            <a asp-action="Index" class="btn btn-outline-secondary w-100" title="Clear">
                <i class="fas fa-times"></i>
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-clipboard-list"></i>
        <h5>No open requests</h5>
        <p>There are no open requests matching your categories right now. Check back later.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var req in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="k-card h-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge bg-primary badge-status">
                            <i class="fas fa-tag me-1"></i>@req.Category?.Name
                        </span>
                        <small class="text-muted">@req.CreatedAt.ToString("MMM dd")</small>
                    </div>

                    <h6 class="fw-700 mb-1">@req.Title</h6>
                    <p class="text-muted small mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                        @req.Description
                    </p>

                    <ul class="list-unstyled small text-muted mb-3">
                        <li class="mb-1">
                            <i class="fas fa-map-marker-alt me-2 text-primary"></i>@req.City
                        </li>
                        <li>
                            <i class="fas fa-calendar me-2 text-primary"></i>
                            @req.PreferredDate.ToString("MMM dd, yyyy")
                        </li>
                    </ul>

                    @if (req.Images != null && req.Images.Any())
                    {
                        <div class="row g-1 mb-3">
                            @foreach (var img in req.Images.Take(3))
                            {
                                <div class="col-4">
                                    <img src="@img.ImageUrl" class="img-fluid rounded"
                                         style="height:50px;width:100%;object-fit:cover;" />
                                </div>
                            }
                        </div>
                    }

                    <a asp-action="Details" asp-route-id="@req.Id"
                       class="btn btn-sm btn-outline-primary w-100">
                        View & Submit Offer <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        }
    </div>
}
