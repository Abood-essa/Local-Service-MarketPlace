@using Local_Service_marketPlace.Models
@using Local_Service_marketPlace.Models.Enums
@model Local_Service_marketPlace.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
    Layout = "~/Areas/Provider/Views/Shared/_ProviderLayout.cshtml";
    var profile = ViewBag.Profile as ProviderProfile;
}

@{
    var (bBadge, bIcon) = Model.BookingStatus switch
    {
        BookingStatus.Active => ("bg-primary", "fa-play-circle"),
        BookingStatus.InProgress => ("bg-warning text-dark", "fa-spinner"),
        BookingStatus.PendingCompletion => ("bg-info text-dark", "fa-hourglass-end"),
        BookingStatus.Completed => ("bg-success", "fa-check-double"),
        BookingStatus.Cancelled => ("bg-danger", "fa-times-circle"),
        BookingStatus.Disputed => ("bg-dark", "fa-exclamation-triangle"),
        _ => ("bg-secondary", "fa-question")
    };
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Back to My Bookings
    </a>
    <span class="badge @bBadge badge-status fs-6">
        <i class="fas @bIcon me-1"></i>@Model.BookingStatus
    </span>
</div>

<div class="row g-4">

    @* Left column *@
    <div class="col-lg-5">

        @* Service info *@
        <div class="k-card mb-3">
            <h6 class="fw-700 mb-3">
                <i class="fas fa-clipboard-list text-primary me-2"></i>Service Details
            </h6>
            <p class="fw-600 mb-1">@Model.ServiceRequest?.Title</p>
            <ul class="list-unstyled small text-muted">
                <li class="mb-1">
                    <i class="fas fa-tag me-2 text-primary"></i>@Model.ServiceRequest?.Category?.Name
                </li>
                <li class="mb-1">
                    <i class="fas fa-map-marker-alt me-2 text-primary"></i>
                    @Model.ServiceRequest?.Address, @Model.ServiceRequest?.City
                </li>
                <li>
                    <i class="fas fa-calendar me-2 text-primary"></i>
                    @Model.ServiceRequest?.PreferredDate.ToString("MMMM dd, yyyy")
                </li>
            </ul>

            @if (Model.ServiceRequest?.Images != null && Model.ServiceRequest.Images.Any())
            {
                <div class="row g-1 mt-2">
                    @foreach (var img in Model.ServiceRequest.Images)
                    {
                        <div class="col-3">
                            <a href="@img.ImageUrl" target="_blank">
                                <img src="@img.ImageUrl" class="img-fluid rounded"
                                     style="height:60px;width:100%;object-fit:cover;" />
                            </a>
                        </div>
                    }
                </div>
            }
        </div>

        @* Customer info *@
        <div class="k-card mb-3">
            <h6 class="fw-700 mb-3">
                <i class="fas fa-user text-primary me-2"></i>Customer
            </h6>
            <p class="fw-600 mb-1">
                @Model.Customer?.FirstName @Model.Customer?.LastName
            </p>
            <p class="small text-muted mb-0">
                <i class="fas fa-phone me-1"></i>@Model.Customer?.PhoneNumber
            </p>
        </div>

        @* Earnings *@
        <div class="k-card">
            <h6 class="fw-700 mb-3">
                <i class="fas fa-wallet text-primary me-2"></i>Earnings
            </h6>
            <div class="d-flex justify-content-between small mb-1">
                <span class="text-muted">Final Price</span>
                <span class="fw-600">@Model.FinalConfirmedPrice JD</span>
            </div>
            <div class="d-flex justify-content-between small mb-1">
                <span class="text-muted">Platform Fee (@Model.CommissionPercentage%)</span>
                <span class="text-danger">-@Model.CommissionAmount JD</span>
            </div>
            <hr class="my-2" />
            <div class="d-flex justify-content-between">
                <span class="fw-700">Your Earnings</span>
                <span class="fw-700 text-success fs-5">@Model.ProviderEarnings JD</span>
            </div>
            @if (Model.Payment != null)
            {
                <div class="mt-2 text-success small">
                    <i class="fas fa-check-circle me-1"></i>
                    Payment confirmed on @Model.Payment.TransactionDate.ToString("MMM dd, yyyy")
                </div>
            }
        </div>

    </div>

    @* Right column *@
    <div class="col-lg-7">

        @* Timeline *@
        <div class="k-card mb-3">
            <h6 class="fw-700 mb-3">
                <i class="fas fa-stream text-primary me-2"></i>Job Timeline
            </h6>
            <ul class="list-unstyled small">
                <li class="mb-2 text-success">
                    <i class="fas fa-check-circle me-2"></i>
                    <strong>Booked</strong> — @Model.CreatedAt.ToString("MMM dd, yyyy")
                </li>
                <li class="mb-2 @(Model.StartedAt.HasValue ? "text-success" : "text-muted")">
                    <i class="fas fa-@(Model.StartedAt.HasValue ? "check-circle" : "circle") me-2"></i>
                    <strong>Started</strong>
                    @(Model.StartedAt.HasValue
                                        ? "— " + Model.StartedAt.Value.ToString("MMM dd, yyyy")
                                        : "— Not started yet")
                </li>
                <li class="mb-2 @(Model.BookingStatus == BookingStatus.PendingCompletion || Model.BookingStatus == BookingStatus.Completed ? "text-success" : "text-muted")">
                    <i class="fas fa-@(Model.BookingStatus == BookingStatus.PendingCompletion || Model.BookingStatus == BookingStatus.Completed ? "check-circle" : "circle") me-2"></i>
                    <strong>Marked Done</strong>
                    @(Model.BookingStatus == BookingStatus.PendingCompletion || Model.BookingStatus == BookingStatus.Completed
                                        ? ""
                                        : "— Pending")
                </li>
                <li class="@(Model.CompletedAt.HasValue ? "text-success" : "text-muted")">
                    <i class="fas fa-@(Model.CompletedAt.HasValue ? "check-double" : "circle") me-2"></i>
                    <strong>Confirmed by Customer</strong>
                    @(Model.CompletedAt.HasValue
                                        ? "— " + Model.CompletedAt.Value.ToString("MMM dd, yyyy")
                                        : "— Waiting for customer")
                </li>
            </ul>
        </div>

        @* Active — start the job *@
        @if (Model.BookingStatus == BookingStatus.Active)
        {
            <div class="k-card mb-3 border-start border-primary border-3">
                <h6 class="fw-700 mb-2">
                    <i class="fas fa-play-circle text-primary me-2"></i>Start the Job
                </h6>
                <p class="small text-muted mb-3">
                    Head to the customer's location and mark the job as started.
                </p>
                <form asp-action="MarkInProgress" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Mark this job as In Progress?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-play me-1"></i> Mark as In Progress
                    </button>
                </form>
            </div>
        }

        @* InProgress — mark done *@
        @if (Model.BookingStatus == BookingStatus.InProgress)
        {
            <div class="k-card mb-3 border-start border-success border-3">
                <h6 class="fw-700 mb-2">
                    <i class="fas fa-check text-success me-2"></i>Mark Job as Done
                </h6>
                <p class="small text-muted mb-3">
                    Once the work is finished, mark the job as done. The customer will then confirm completion.
                </p>
                <form asp-action="MarkDone" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Mark this job as completed?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check-double me-1"></i> Mark as Done
                    </button>
                </form>
            </div>
        }

        @* PendingCompletion — waiting *@
        @if (Model.BookingStatus == BookingStatus.PendingCompletion)
        {
            <div class="k-card mb-3 border-start border-info border-3">
                <h6 class="fw-700 text-info mb-2">
                    <i class="fas fa-hourglass-end me-2"></i>Waiting for Confirmation
                </h6>
                <p class="small text-muted mb-0">
                    You've marked the job as done. Waiting for the customer to confirm completion.
                </p>
            </div>
        }

        @* Review received *@
        @if (Model.Review != null)
        {
            <div class="k-card mt-3 border-start border-warning border-3">
                <h6 class="fw-700 mb-2">
                    <i class="fas fa-star text-warning me-2"></i>Customer Review
                </h6>
                <div class="mb-1">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="fas fa-star @(i <= Model.Review.Rating ? "text-warning" : "text-muted")"></i>
                    }
                    <span class="ms-1 small text-muted">(@Model.Review.Rating/5)</span>
                </div>
                @if (!string.IsNullOrEmpty(Model.Review.Comment))
                {
                    <p class="small text-muted mb-0">@Model.Review.Comment</p>
                }
            </div>
        }

        @* ── File a Complaint ── *@
        @if (Model.BookingStatus != BookingStatus.Cancelled)
        {
            <div class="k-card mt-3 border-start border-danger border-3">
                <h6 class="fw-700 mb-2 text-danger">
                    <i class="fas fa-flag me-2"></i>Report an Issue
                </h6>
                <p class="small text-muted mb-3">
                    Experienced a problem with this booking? File a complaint and our
                    team will investigate within 24–48 hours.
                </p>
                <a asp-area="Provider" asp-controller="Complaint" asp-action="Create"
                   asp-route-bookingId="@Model.Id"
                   class="btn btn-sm btn-outline-danger">
                    <i class="fas fa-flag me-1"></i> File a Complaint
                </a>
            </div>
        }

    </div>
</div>
