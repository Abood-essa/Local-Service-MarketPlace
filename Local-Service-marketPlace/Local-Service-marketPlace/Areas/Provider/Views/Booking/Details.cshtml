@using Local_Service_marketPlace.Models.Enums
@model Local_Service_marketPlace.Models.Booking
@{
    ViewData["Title"] = "Booking Details";
    Layout = "~/Areas/Provider/Views/Shared/_ProviderLayout.cshtml";

    var (statusClass, statusIcon) = Model.BookingStatus switch
    {
        BookingStatus.Active => ("kh-status-soft-primary", "fa-play-circle"),
        BookingStatus.InProgress => ("kh-status-soft-warning", "fa-spinner"),
        BookingStatus.PendingCompletion => ("kh-status-soft-blue", "fa-hourglass-end"),
        BookingStatus.Completed => ("kh-status-soft-success", "fa-check-double"),
        BookingStatus.Cancelled => ("kh-status-soft-danger", "fa-times-circle"),
        BookingStatus.Disputed => ("kh-status-soft-muted", "fa-triangle-exclamation"),
        _ => ("kh-status-soft-muted", "fa-question")
    };

    var markedDone = Model.BookingStatus == BookingStatus.PendingCompletion || Model.BookingStatus == BookingStatus.Completed;
}

<div class="marketplace-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <section class="kh-page-hero">
        <div class="kh-card-topline mb-3">
            <a asp-action="Index" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left me-1"></i> Back to bookings
            </a>
            <span class="kh-status-badge @statusClass">
                <i class="fas @statusIcon"></i>@Model.BookingStatus
            </span>
        </div>
        <div class="kh-hero-grid">
            <div>
                <div class="kh-hero-kicker">
                    <i class="fas fa-briefcase"></i>
                    Manage booking
                </div>
                <h1 class="kh-page-title">@Model.ServiceRequest?.Title</h1>
                <p class="kh-page-copy">
                    Keep the customer updated, follow the job timeline, and review payout details without hunting through separate cards.
                </p>
            </div>
            <div class="kh-hero-panel">
                <div class="kh-inline-between">
                    <div>
                        <div class="kh-stat-label">Your earnings</div>
                        <div class="fs-2 fw-800">@Model.ProviderEarnings.ToString("0.##") JD</div>
                    </div>
                    <span class="icon-chip bg-white"><i class="fas fa-sack-dollar"></i></span>
                </div>
                <div class="small text-white-50 mt-2">
                    Final price @Model.FinalConfirmedPrice.ToString("0.##") JD after @Model.CommissionPercentage.ToString("0.##")% platform fee.
                </div>
            </div>
        </div>
    </section>

    <div class="kh-detail-layout">
        <div class="kh-detail-stack">
            <section class="kh-info-card">
                <h2 class="h5 mb-3"><i class="fas fa-clipboard-list text-primary me-2"></i>Service overview</h2>
                <p class="text-muted mb-3">@Model.ServiceRequest?.Description</p>
                <div class="kh-info-row">
                    <span class="kh-info-icon"><i class="fas fa-tag"></i></span>
                    <div>
                        <div class="small text-muted">Category</div>
                        <div class="fw-800">@Model.ServiceRequest?.Category?.Name</div>
                    </div>
                </div>
                <div class="kh-info-row">
                    <span class="kh-info-icon"><i class="fas fa-location-dot"></i></span>
                    <div>
                        <div class="small text-muted">Location</div>
                        <div class="fw-800">@Model.ServiceRequest?.Address, @Model.ServiceRequest?.City</div>
                    </div>
                </div>
                <div class="kh-info-row">
                    <span class="kh-info-icon"><i class="fas fa-calendar-day"></i></span>
                    <div>
                        <div class="small text-muted">Preferred date</div>
                        <div class="fw-800">@Model.ServiceRequest?.PreferredDate.ToString("MMMM dd, yyyy")</div>
                    </div>
                </div>
            </section>

            <section class="kh-info-card">
                <h2 class="h5 mb-3"><i class="fas fa-user text-primary me-2"></i>Customer</h2>
                <div class="kh-offer-provider">
                    <span class="kh-avatar-fallback">
                        @(Model.Customer?.FirstName?.Substring(0, 1) ?? "C")
                    </span>
                    <div>
                        <h3 class="h6 mb-1">@Model.Customer?.FirstName @Model.Customer?.LastName</h3>
                        <div class="text-muted small">
                            <i class="fas fa-phone me-1 text-primary"></i>@Model.Customer?.PhoneNumber
                        </div>
                    </div>
                </div>
            </section>

            <section class="kh-info-card">
                <h2 class="h5 mb-3"><i class="fas fa-wallet text-primary me-2"></i>Earnings breakdown</h2>
                <div class="kh-inline-between mb-2">
                    <span class="text-muted">Final price</span>
                    <strong>@Model.FinalConfirmedPrice.ToString("0.##") JD</strong>
                </div>
                <div class="kh-inline-between mb-2">
                    <span class="text-muted">Platform fee (@Model.CommissionPercentage.ToString("0.##")%)</span>
                    <strong class="text-danger">-@Model.CommissionAmount.ToString("0.##") JD</strong>
                </div>
                <hr />
                <div class="kh-inline-between">
                    <span class="fw-800">Your earnings</span>
                    <span class="kh-price fs-4">@Model.ProviderEarnings.ToString("0.##") JD</span>
                </div>
                @if (Model.Payment != null)
                {
                    <div class="kh-status-badge kh-status-soft-success mt-3">
                        <i class="fas fa-check-circle"></i>
                        Payment confirmed @Model.Payment.TransactionDate.ToString("MMM dd, yyyy")
                    </div>
                }
            </section>

            @if (Model.ServiceRequest?.Images != null && Model.ServiceRequest.Images.Any())
            {
                <section class="kh-info-card">
                    <h2 class="h5 mb-3"><i class="fas fa-images text-primary me-2"></i>Request photos</h2>
                    <div class="kh-gallery-grid">
                        @foreach (var img in Model.ServiceRequest.Images)
                        {
                            <a href="@img.ImageUrl" target="_blank" aria-label="Open request photo">
                                <img src="@img.ImageUrl" alt="@Model.ServiceRequest.Title" />
                            </a>
                        }
                    </div>
                </section>
            }
        </div>

        <div class="kh-detail-stack">
            <section class="kh-info-card">
                <h2 class="h5 mb-3"><i class="fas fa-stream text-primary me-2"></i>Job timeline</h2>
                <ul class="kh-timeline">
                    <li class="kh-timeline-item is-done">
                        <span class="kh-timeline-dot"><i class="fas fa-check"></i></span>
                        <div>
                            <strong>Booked</strong>
                            <div class="text-muted small">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                        </div>
                    </li>
                    <li class="kh-timeline-item @(Model.StartedAt.HasValue ? "is-done" : "")">
                        <span class="kh-timeline-dot"><i class="fas @(Model.StartedAt.HasValue ? "fa-check" : "fa-circle")"></i></span>
                        <div>
                            <strong>Started</strong>
                            <div class="text-muted small">
                                @(Model.StartedAt.HasValue ? Model.StartedAt.Value.ToString("MMM dd, yyyy") : "Not started yet")
                            </div>
                        </div>
                    </li>
                    <li class="kh-timeline-item @(markedDone ? "is-done" : "")">
                        <span class="kh-timeline-dot"><i class="fas @(markedDone ? "fa-check" : "fa-circle")"></i></span>
                        <div>
                            <strong>Marked done</strong>
                            <div class="text-muted small">@(markedDone ? "Waiting for or already confirmed by customer" : "Pending")</div>
                        </div>
                    </li>
                    <li class="kh-timeline-item @(Model.CompletedAt.HasValue ? "is-done" : "")">
                        <span class="kh-timeline-dot"><i class="fas @(Model.CompletedAt.HasValue ? "fa-check" : "fa-circle")"></i></span>
                        <div>
                            <strong>Confirmed by customer</strong>
                            <div class="text-muted small">
                                @(Model.CompletedAt.HasValue ? Model.CompletedAt.Value.ToString("MMM dd, yyyy") : "Waiting for customer")
                            </div>
                        </div>
                    </li>
                </ul>
            </section>

            @if (Model.BookingStatus == BookingStatus.Active)
            {
                <section class="kh-action-panel">
                    <h2 class="h5 fw-800 mb-2"><i class="fas fa-play-circle text-primary me-2"></i>Start the job</h2>
                    <p class="text-muted small mb-3">Head to the customer's location and mark the booking as in progress.</p>
                    <form asp-action="MarkInProgress" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Mark this job as In Progress?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-play me-1"></i> Mark as in progress
                        </button>
                    </form>
                </section>
            }

            @if (Model.BookingStatus == BookingStatus.InProgress)
            {
                <section class="kh-action-panel success">
                    <h2 class="h5 fw-800 mb-2"><i class="fas fa-check text-success me-2"></i>Mark job as done</h2>
                    <p class="text-muted small mb-3">When the work is finished, send it to the customer for completion confirmation.</p>
                    <form asp-action="MarkDone" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Mark this job as completed?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-success">
                            <i class="fas fa-check-double me-1"></i> Mark as done
                        </button>
                    </form>
                </section>
            }

            @if (Model.BookingStatus == BookingStatus.PendingCompletion)
            {
                <section class="kh-action-panel warning">
                    <h2 class="h5 fw-800 mb-2"><i class="fas fa-hourglass-end text-primary me-2"></i>Waiting for confirmation</h2>
                    <p class="text-muted small mb-0">You marked the job as done. The customer needs to confirm completion before payout is finalized.</p>
                </section>
            }

            @if (Model.Review != null)
            {
                <section class="kh-info-card">
                    <h2 class="h5 mb-3"><i class="fas fa-star text-warning me-2"></i>Customer review</h2>
                    <div class="mb-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fas fa-star @(i <= Model.Review.Rating ? "text-warning" : "text-muted")"></i>
                        }
                        <span class="ms-1 small text-muted">(@Model.Review.Rating/5)</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Review.Comment))
                    {
                        <p class="text-muted mb-0">@Model.Review.Comment</p>
                    }
                </section>
            }

            @if (Model.BookingStatus != BookingStatus.Cancelled)
            {
                <section class="kh-action-panel danger">
                    <h2 class="h5 fw-800 mb-2 text-danger"><i class="fas fa-flag me-2"></i>Report an issue</h2>
                    <p class="text-muted small mb-3">If something is wrong with this booking, send the case to support for review.</p>
                    <a asp-area="Provider" asp-controller="Complaint" asp-action="Create"
                       asp-route-bookingId="@Model.Id" class="btn btn-outline-danger">
                        <i class="fas fa-flag me-1"></i> File a complaint
                    </a>
                </section>
            }
        </div>
    </div>
</div>
