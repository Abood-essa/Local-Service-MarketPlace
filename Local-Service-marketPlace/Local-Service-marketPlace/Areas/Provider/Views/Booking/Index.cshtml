@using Local_Service_marketPlace.Models.Enums
@model IEnumerable<Local_Service_marketPlace.Models.Booking>
@{
    ViewData["Title"] = "My Bookings";
    Layout = "~/Areas/Provider/Views/Shared/_ProviderLayout.cshtml";

    var bookings = Model.ToList();
    var totalBookings = bookings.Count;
    var activeJobs = bookings.Count(b => b.BookingStatus == BookingStatus.Active || b.BookingStatus == BookingStatus.InProgress);
    var awaitingConfirmation = bookings.Count(b => b.BookingStatus == BookingStatus.PendingCompletion);
    var completedJobs = bookings.Count(b => b.BookingStatus == BookingStatus.Completed);
    var totalEarnings = bookings.Where(b => b.BookingStatus != BookingStatus.Cancelled).Sum(b => b.ProviderEarnings);
    var currentStatus = ViewBag.Status as string;
}

<div class="marketplace-page">
    <section class="kh-page-hero">
        <div class="kh-hero-grid">
            <div>
                <div class="kh-hero-kicker">
                    <i class="fas fa-calendar-check"></i>
                    Provider bookings
                </div>
                <h1 class="kh-page-title">Keep every confirmed job moving.</h1>
                <p class="kh-page-copy">
                    Track active work, spot jobs waiting on customer confirmation, and review your earnings from one polished workspace.
                </p>
            </div>
            <div class="kh-hero-panel">
                <div class="kh-inline-between">
                    <div>
                        <div class="kh-stat-label">Visible earnings</div>
                        <div class="fs-2 fw-800">@totalEarnings.ToString("0.##") JD</div>
                    </div>
                    <span class="icon-chip bg-white"><i class="fas fa-wallet"></i></span>
                </div>
                <p class="small mb-0 mt-2 text-white-50">Based on the bookings currently shown by the active filter.</p>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <section class="kh-metric-grid">
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-layer-group"></i></span>
            <div class="kh-metric-number">@totalBookings</div>
            <div class="kh-metric-label">Total bookings</div>
        </article>
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-person-digging"></i></span>
            <div class="kh-metric-number">@activeJobs</div>
            <div class="kh-metric-label">Active or in progress</div>
        </article>
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-hourglass-half"></i></span>
            <div class="kh-metric-number">@awaitingConfirmation</div>
            <div class="kh-metric-label">Awaiting customer</div>
        </article>
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-check-double"></i></span>
            <div class="kh-metric-number">@completedJobs</div>
            <div class="kh-metric-label">Completed</div>
        </article>
    </section>

    <section class="kh-filter-panel">
        <div class="kh-filter-title">
            <i class="fas fa-filter"></i>
            Booking status
        </div>
        <form method="get" class="kh-chip-row">
            <a asp-action="Index"
               class="kh-filter-chip @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">
                <i class="fas fa-border-all"></i> All
            </a>
            @foreach (var s in Enum.GetValues<BookingStatus>())
            {
                var icon = s switch
                {
                    BookingStatus.Active => "fa-play",
                    BookingStatus.InProgress => "fa-spinner",
                    BookingStatus.PendingCompletion => "fa-hourglass-end",
                    BookingStatus.Completed => "fa-check-double",
                    BookingStatus.Cancelled => "fa-ban",
                    BookingStatus.Disputed => "fa-triangle-exclamation",
                    _ => "fa-circle"
                };
                <a asp-action="Index" asp-route-status="@s"
                   class="kh-filter-chip @(currentStatus == s.ToString() ? "active" : "")">
                    <i class="fas @icon"></i> @s
                </a>
            }
        </form>
    </section>

    @if (!bookings.Any())
    {
        <div class="empty-state">
            <i class="fas fa-calendar-times"></i>
            <h5>No bookings yet</h5>
            <p>Once a customer accepts your offer, the booking will appear here.</p>
            <a asp-area="Provider" asp-controller="ServiceRequest" asp-action="Index" class="btn btn-primary">
                Browse Requests
            </a>
        </div>
    }
    else
    {
        <section class="kh-card-grid two-col">
            @foreach (var booking in bookings)
            {
                var (statusClass, statusIcon) = booking.BookingStatus switch
                {
                    BookingStatus.Active => ("kh-status-soft-primary", "fa-play-circle"),
                    BookingStatus.InProgress => ("kh-status-soft-warning", "fa-spinner"),
                    BookingStatus.PendingCompletion => ("kh-status-soft-blue", "fa-hourglass-end"),
                    BookingStatus.Completed => ("kh-status-soft-success", "fa-check-double"),
                    BookingStatus.Cancelled => ("kh-status-soft-danger", "fa-times-circle"),
                    BookingStatus.Disputed => ("kh-status-soft-muted", "fa-triangle-exclamation"),
                    _ => ("kh-status-soft-muted", "fa-question")
                };

                <article class="kh-booking-card">
                    <div class="kh-card-topline">
                        <span class="kh-status-badge @statusClass">
                            <i class="fas @statusIcon"></i>@booking.BookingStatus
                        </span>
                        <small class="text-muted">Booked @booking.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>

                    <div>
                        <h3 class="kh-card-title">@booking.ServiceRequest?.Title</h3>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            <span class="kh-status-badge kh-status-soft-muted">
                                <i class="fas fa-tag"></i>@booking.ServiceRequest?.Category?.Name
                            </span>
                            <span class="kh-status-badge kh-status-soft-muted">
                                <i class="fas fa-location-dot"></i>@booking.ServiceRequest?.City
                            </span>
                        </div>
                    </div>

                    <div class="kh-info-row">
                        <span class="kh-info-icon"><i class="fas fa-user"></i></span>
                        <div>
                            <div class="small text-muted">Customer</div>
                            <div class="fw-800">@booking.Customer?.FirstName @booking.Customer?.LastName</div>
                        </div>
                    </div>

                    <div class="kh-inline-between mt-auto">
                        <div>
                            <div class="small text-muted">Provider earnings</div>
                            <div class="kh-price fs-5">@booking.ProviderEarnings.ToString("0.##") JD</div>
                        </div>
                        <a asp-action="Details" asp-route-id="@booking.Id" class="btn btn-outline-primary">
                            Manage <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </article>
            }
        </section>
    }
</div>
