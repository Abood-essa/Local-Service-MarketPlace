@using Local_Service_marketPlace.Models
@model Local_Service_marketPlace.Models.ProviderProfile
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Areas/Provider/Views/Shared/_ProviderLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="fas fa-user-cog text-primary me-2"></i>My Profile</h2>
        <p>Your public provider profile as customers see it.</p>
    </div>
    <a asp-action="Edit" class="btn btn-primary">
        <i class="fas fa-user-edit me-1"></i> Edit Profile
    </a>
</div>

<div class="row g-4">

    @* Profile card *@
    <div class="col-lg-4">
        <div class="k-card text-center">
            @if (!string.IsNullOrEmpty(Model.ProfileImage))
            {
                <img src="@Model.ProfileImage" class="rounded-circle mb-3"
                     style="width:80px;height:80px;object-fit:cover;" />
            }
            else
            {
                <div class="rounded-circle bg-primary d-inline-flex align-items-center
                    justify-content-center text-white fw-800 mb-3"
                     style="width:80px;height:80px;font-size:2rem;">
                    @Model.User?.FirstName?.Substring(0, 1)
                </div>
            }
            <h5 class="fw-700 mb-1">@Model.User?.FirstName @Model.User?.LastName</h5>
            <p class="text-muted small mb-2">@Model.User?.Email</p>
            <p class="text-muted small mb-3">
                <i class="fas fa-phone me-1"></i>@Model.User?.PhoneNumber
            </p>

            <div class="mb-3">
                @if (Model.IsVerified)
                {
                    <span class="badge bg-success fs-6 px-3 py-2">
                        <i class="fas fa-shield-alt me-1"></i>Verified Provider
                    </span>
                }
                else
                {
                    <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                        <i class="fas fa-hourglass-half me-1"></i>Pending Verification
                    </span>
                }
            </div>

            <div class="mb-3">
                <div class="small text-muted mb-1">Wallet Balance</div>
                <div class="fw-700 fs-5 @(Model.WalletBalance < 0 ? "text-danger" : "text-success")">
                    @Model.WalletBalance.ToString("0.00") JD
                </div>
                @if (Model.WalletBalance < 0)
                {
                    <div class="small text-danger">
                        <i class="fas fa-exclamation-triangle me-1"></i>Top up required
                    </div>
                }
            </div>

            <div class="row g-2 text-center">
                <div class="col-4">
                    <div class="fw-700 text-primary fs-5">@Model.AverageRating.ToString("0.0")</div>
                    <div class="text-muted" style="font-size:.75rem;">Rating</div>
                </div>
                <div class="col-4">
                    <div class="fw-700 text-primary fs-5">@Model.CompletedJobsCount</div>
                    <div class="text-muted" style="font-size:.75rem;">Jobs</div>
                </div>
                <div class="col-4">
                    <div class="fw-700 text-primary fs-5">@Model.YearsOfExperience</div>
                    <div class="text-muted" style="font-size:.75rem;">Yrs Exp</div>
                </div>
            </div>
        </div>
    </div>

    @* Details *@
    <div class="col-lg-8">
        <div class="k-card mb-3">
            <h6 class="fw-700 mb-3">
                <i class="fas fa-info-circle text-primary me-2"></i>About
            </h6>
            <p class="text-muted mb-0">
                @(string.IsNullOrEmpty(Model.Bio) ? "No bio provided." : Model.Bio)
            </p>
        </div>

        <div class="k-card mb-3">
            <h6 class="fw-700 mb-3">
                <i class="fas fa-clock text-primary me-2"></i>Availability
            </h6>
            <p class="text-muted mb-0">
                @Model.AvailableFrom.ToString(@"hh\:mm") — @Model.AvailableTo.ToString(@"hh\:mm")
            </p>
        </div>

        <div class="k-card mb-3">
            <h6 class="fw-700 mb-3">
                <i class="fas fa-tags text-primary me-2"></i>Service Categories
            </h6>
            <div class="d-flex flex-wrap gap-2">
                @if (Model.ProviderCategories != null && Model.ProviderCategories.Any())
                {
                    @foreach (var pc in Model.ProviderCategories)
                    {
                        <span class="badge bg-primary px-3 py-2">@pc.Category?.Name</span>
                    }
                }
                else
                {
                    <p class="text-muted small mb-0">No categories selected.</p>
                }
            </div>
        </div>

        @* Reviews *@
        @if (Model.ReviewsReceived != null && Model.ReviewsReceived.Any())
        {
            <div class="k-card">
                <h6 class="fw-700 mb-3">
                    <i class="fas fa-star text-warning me-2"></i>
                    Reviews (@Model.ReviewsReceived.Count)
                </h6>
                @foreach (var r in Model.ReviewsReceived.OrderByDescending(r => r.CreatedAt))
                {
                    <div class="border-bottom pb-3 mb-3">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <div>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="fas fa-star @(i <= r.Rating ? "text-warning" : "text-muted")"
                                       style="font-size:.85rem;"></i>
                                }
                                <span class="ms-2 small fw-600">
                                    @r.Customer?.FirstName @r.Customer?.LastName
                                </span>
                            </div>
                            <small class="text-muted">@r.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                        @if (!string.IsNullOrEmpty(r.Comment))
                        {
                            <p class="small text-muted mb-0">@r.Comment</p>
                        }
                    </div>
                }
            </div>
        }

    </div>
</div>
