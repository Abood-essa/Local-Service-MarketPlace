@using Local_Service_marketPlace.Models.Enums
@model Local_Service_marketPlace.Models.ServiceRequest
@{
    ViewData["Title"] = "Request Details";
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
}

@{
    var (badgeCss, statusIcon) = Model.Status switch
    {
        ServiceRequestStatus.Pending               => ("bg-warning text-dark", "fa-clock"),
        ServiceRequestStatus.OfferReceived         => ("bg-info text-dark", "fa-envelope-open"),
        ServiceRequestStatus.WaitingForConfirmation => ("bg-primary", "fa-hourglass-half"),
        ServiceRequestStatus.Confirmed             => ("bg-success", "fa-check-circle"),
        ServiceRequestStatus.InProgress            => ("bg-primary", "fa-spinner"),
        ServiceRequestStatus.Completed             => ("bg-success", "fa-check-double"),
        ServiceRequestStatus.Cancelled             => ("bg-danger", "fa-times-circle"),
        _                                          => ("bg-secondary", "fa-question")
    };

    bool canCancel = Model.Status != ServiceRequestStatus.Confirmed
                  && Model.Status != ServiceRequestStatus.InProgress
                  && Model.Status != ServiceRequestStatus.Completed
                  && Model.Status != ServiceRequestStatus.Cancelled;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i> Back to My Requests
    </a>
    @if (canCancel)
    {
        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
              onsubmit="return confirm('Cancel this request?')">
            @Html.AntiForgeryToken()
            <button class="btn btn-sm btn-outline-danger">
                <i class="fas fa-times me-1"></i> Cancel Request
            </button>
        </form>
    }
</div>

<div class="row g-4">

    <div class="col-lg-5">
        <div class="k-card">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h5 class="fw-700 mb-0">@Model.Title</h5>
                <span class="badge @badgeCss badge-status">
                    <i class="fas @statusIcon me-1"></i>@Model.Status
                </span>
            </div>

            <p class="text-muted small mb-3">@Model.Description</p>

            <ul class="list-unstyled small text-muted mb-3">
                <li class="mb-1">
                    <i class="fas fa-tag me-2 text-primary"></i>
                    <strong>Category:</strong> @Model.Category?.Name
                </li>
                <li class="mb-1">
                    <i class="fas fa-map-marker-alt me-2 text-primary"></i>
                    <strong>Location:</strong> @Model.Address, @Model.City
                </li>
                <li class="mb-1">
                    <i class="fas fa-calendar me-2 text-primary"></i>
                    <strong>Preferred Date:</strong> @Model.PreferredDate.ToString("MMMM dd, yyyy")
                </li>
                <li>
                    <i class="fas fa-clock me-2 text-primary"></i>
                    <strong>Posted:</strong> @Model.CreatedAt.ToString("MMM dd, yyyy")
                </li>
            </ul>

            @if (Model.Images != null && Model.Images.Any())
            {
                <div class="row g-2 mt-1">
                    @foreach (var img in Model.Images)
                    {
                        <div class="col-4">
                            <a href="@img.ImageUrl" target="_blank">
                                <img src="@img.ImageUrl" class="img-fluid rounded"
                                     style="height:80px; width:100%; object-fit:cover;" />
                            </a>
                        </div>
                    }
                </div>
            }
        </div>

        @if (Model.Booking != null)
        {
            <div class="k-card border-start border-success border-3">
                <h6 class="fw-700 text-success mb-2">
                    <i class="fas fa-calendar-check me-2"></i>Active Booking
                </h6>
                <p class="small text-muted mb-2">
                    This request has an active booking. Track it from your bookings page.
                </p>
                <a asp-area="Customer" asp-controller="Booking" asp-action="Details"
                   asp-route-id="@Model.Booking.Id" class="btn btn-sm btn-success">
                    View Booking <i class="fas fa-arrow-right ms-1"></i>
                </a>
            </div>
        }
    </div>

    <div class="col-lg-7">
        <h5 class="fw-700 mb-3">
            <i class="fas fa-file-alt text-primary me-2"></i>
            Offers Received
            <span class="badge bg-primary ms-1">@(Model.Offers?.Count ?? 0)</span>
        </h5>

        @if (Model.Offers == null || !Model.Offers.Any())
        {
            <div class="empty-state">
                <i class="fas fa-inbox"></i>
                <h5>No offers yet</h5>
                <p>Providers will send offers once they see your request. Check back soon.</p>
            </div>
        }
        else
        {
            @foreach (var offer in Model.Offers.OrderByDescending(o => o.CreatedAt))
            {
                
                    var offerBadge = offer.Status switch
                    {
                        OfferStatus.Pending                => ("bg-warning text-dark", "Pending"),
                        OfferStatus.FinalPriceSubmitted    => ("bg-info text-dark", "Final Price Ready"),
                        OfferStatus.AcceptedByCustomer     => ("bg-success", "Accepted"),
                        OfferStatus.RejectedByCustomer     => ("bg-danger", "Rejected"),
                        _                                  => ("bg-secondary", offer.Status.ToString())
                    };
                

                <div class="k-card mb-3 @(offer.Status == OfferStatus.AcceptedByCustomer ? "border-start border-success border-3" : "")">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <span class="fw-600">
                                @offer.ProviderProfile?.User?.FirstName
                                @offer.ProviderProfile?.User?.LastName
                            </span>
                            @if (offer.ProviderProfile?.IsVerified == true)
                            {
                                <span class="badge bg-success ms-1" title="Verified Provider">
                                    <i class="fas fa-shield-alt"></i> Verified
                                </span>
                            }
                            <div class="text-muted small mt-1">
                                <i class="fas fa-star text-warning me-1"></i>
                                @offer.ProviderProfile?.AverageRating.ToString("0.0")
                                &nbsp;·&nbsp;
                                @offer.ProviderProfile?.CompletedJobsCount jobs completed
                            </div>
                        </div>
                        <span class="badge @offerBadge.Item1">@offerBadge.Item2</span>
                    </div>

                    <div class="row g-2 mb-2">
                        <div class="col-6">
                            <div class="bg-light rounded p-2 text-center small">
                                <div class="text-muted">Estimated Range</div>
                                <div class="fw-700 text-primary">
                                    @offer.EstimatedMinPrice JD — @offer.EstimatedMaxPrice JD
                                </div>
                            </div>
                        </div>
                        @if (offer.FinalPrice.HasValue)
                        {
                            <div class="col-6">
                                <div class="bg-light rounded p-2 text-center small">
                                    <div class="text-muted">Final Price</div>
                                    <div class="fw-700 text-success fs-5">
                                        @offer.FinalPrice JD
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(offer.Notes))
                    {
                        <p class="small text-muted mb-2">
                            <i class="fas fa-comment me-1"></i>@offer.Notes
                        </p>
                    }

                    @if (offer.Status == OfferStatus.FinalPriceSubmitted &&
                         Model.Status != ServiceRequestStatus.Confirmed &&
                         Model.Status != ServiceRequestStatus.Completed &&
                         Model.Status != ServiceRequestStatus.Cancelled)
                    {
                        <div class="d-flex gap-2 mt-2">
                            <form asp-action="AcceptFinalPrice" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="offerId" value="@offer.Id" />
                                <button type="submit" class="btn btn-sm btn-success"
                                        onclick="return confirm('Accept this final price of @offer.FinalPrice JD?')">
                                    <i class="fas fa-check me-1"></i> Accept @offer.FinalPrice JD
                                </button>
                            </form>
                            <form asp-action="RejectOffer" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="offerId" value="@offer.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="fas fa-times me-1"></i> Reject
                                </button>
                            </form>
                        </div>
                    }

                    <div class="text-muted small mt-2">
                        Submitted @offer.CreatedAt.ToString("MMM dd, yyyy")
                    </div>
                </div>
            }
        }
    </div>

</div>
