@using Local_Service_marketPlace.Models.Enums
@model Local_Service_marketPlace.Models.ServiceRequest
@{
    ViewData["Title"] = "Request Details";
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";

    var offers = Model.Offers?.OrderByDescending(o => o.CreatedAt).ToList() ?? new List<Local_Service_marketPlace.Models.ServiceOffer>();
    var (requestStatusClass, requestStatusIcon) = Model.Status switch
    {
        ServiceRequestStatus.Pending => ("kh-status-soft-warning", "fa-clock"),
        ServiceRequestStatus.OfferReceived => ("kh-status-soft-blue", "fa-envelope-open"),
        ServiceRequestStatus.WaitingForConfirmation => ("kh-status-soft-primary", "fa-hourglass-half"),
        ServiceRequestStatus.Confirmed => ("kh-status-soft-success", "fa-check-circle"),
        ServiceRequestStatus.InProgress => ("kh-status-soft-primary", "fa-spinner"),
        ServiceRequestStatus.Completed => ("kh-status-soft-success", "fa-check-double"),
        ServiceRequestStatus.Cancelled => ("kh-status-soft-danger", "fa-times-circle"),
        _ => ("kh-status-soft-muted", "fa-question")
    };

    bool canCancel = Model.Status != ServiceRequestStatus.Confirmed
                  && Model.Status != ServiceRequestStatus.InProgress
                  && Model.Status != ServiceRequestStatus.Completed
                  && Model.Status != ServiceRequestStatus.Cancelled;
}

<div class="marketplace-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <section class="kh-page-hero">
        <div class="kh-card-topline mb-3">
            <a asp-action="Index" class="btn btn-outline-light btn-sm">
                <i class="fas fa-arrow-left me-1"></i> Back to requests
            </a>
            @if (canCancel)
            {
                <form asp-action="Cancel" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Cancel this request?')">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-outline-light btn-sm">
                        <i class="fas fa-times me-1"></i> Cancel request
                    </button>
                </form>
            }
        </div>

        <div class="kh-hero-grid">
            <div>
                <div class="kh-hero-kicker">
                    <i class="fas fa-file-lines"></i>
                    Request details
                </div>
                <h1 class="kh-page-title">@Model.Title</h1>
                <p class="kh-page-copy">@Model.Description</p>
                <div class="kh-hero-actions">
                    <span class="kh-status-badge @requestStatusClass">
                        <i class="fas @requestStatusIcon"></i>@Model.Status
                    </span>
                    <span class="kh-status-badge kh-status-soft-blue">
                        <i class="fas fa-inbox"></i>@offers.Count offer@(offers.Count == 1 ? "" : "s")
                    </span>
                </div>
            </div>
            <div class="kh-hero-panel">
                <div class="kh-info-row border-0 p-0 mb-3">
                    <span class="kh-info-icon"><i class="fas fa-calendar-day"></i></span>
                    <div>
                        <div class="kh-stat-label">Preferred date</div>
                        <div class="fs-5 fw-800">@Model.PreferredDate.ToString("MMM dd, yyyy")</div>
                    </div>
                </div>
                <div class="kh-info-row border-0 p-0">
                    <span class="kh-info-icon"><i class="fas fa-location-dot"></i></span>
                    <div>
                        <div class="kh-stat-label">Location</div>
                        <div class="fw-800">@Model.City</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="kh-detail-layout">
        <div class="kh-detail-stack">
            <section class="kh-info-card">
                <h2 class="h5 mb-3"><i class="fas fa-circle-info text-primary me-2"></i>Request summary</h2>
                <div class="kh-info-row">
                    <span class="kh-info-icon"><i class="fas fa-tag"></i></span>
                    <div>
                        <div class="small text-muted">Category</div>
                        <div class="fw-800">@Model.Category?.Name</div>
                    </div>
                </div>
                <div class="kh-info-row">
                    <span class="kh-info-icon"><i class="fas fa-map-location-dot"></i></span>
                    <div>
                        <div class="small text-muted">Full address</div>
                        <div class="fw-800">@Model.Address, @Model.City</div>
                    </div>
                </div>
                <div class="kh-info-row">
                    <span class="kh-info-icon"><i class="fas fa-clock"></i></span>
                    <div>
                        <div class="small text-muted">Posted</div>
                        <div class="fw-800">@Model.CreatedAt.ToString("MMM dd, yyyy")</div>
                    </div>
                </div>
            </section>

            @if (Model.Images != null && Model.Images.Any())
            {
                <section class="kh-info-card">
                    <h2 class="h5 mb-3"><i class="fas fa-images text-primary me-2"></i>Photos</h2>
                    <div class="kh-gallery-grid">
                        @foreach (var img in Model.Images)
                        {
                            <a href="@img.ImageUrl" target="_blank" aria-label="Open request image">
                                <img src="@img.ImageUrl" alt="@Model.Title" />
                            </a>
                        }
                    </div>
                </section>
            }

            @if (Model.Booking != null)
            {
                <section class="kh-action-panel success">
                    <h2 class="h5 fw-800 mb-2"><i class="fas fa-calendar-check text-success me-2"></i>Active booking</h2>
                    <p class="text-muted small mb-3">This request has an active booking. Track progress from your bookings page.</p>
                    <a asp-area="Customer" asp-controller="Booking" asp-action="Details"
                       asp-route-id="@Model.Booking.Id" class="btn btn-success">
                        View booking <i class="fas fa-arrow-right ms-1"></i>
                    </a>
                </section>
            }
        </div>

        <div class="kh-detail-stack">
            <section class="kh-filter-panel">
                <div class="kh-section-head mb-3">
                    <div>
                        <h2 class="kh-section-title">Provider bids</h2>
                        <p class="kh-section-copy">Compare provider profiles, estimates, final prices, and notes.</p>
                    </div>
                    <span class="kh-status-badge kh-status-soft-primary">
                        <i class="fas fa-file-signature"></i>@offers.Count total
                    </span>
                </div>

                <div class="kh-filter-title">
                    <i class="fas fa-sliders"></i>
                    Filter offers
                </div>
                <div class="kh-chip-row" id="offerFilterChips">
                    <button type="button" class="kh-filter-chip active" data-offer-filter="all">
                        <i class="fas fa-border-all"></i> All
                    </button>
                    @foreach (var status in Enum.GetValues<OfferStatus>())
                    {
                        <button type="button" class="kh-filter-chip" data-offer-filter="@status">
                            <i class="fas fa-circle"></i> @status
                        </button>
                    }
                </div>
            </section>

            @if (!offers.Any())
            {
                <div class="empty-state">
                    <i class="fas fa-inbox"></i>
                    <h5>No offers yet</h5>
                    <p>Providers will send offers once they see your request. Check back soon.</p>
                </div>
            }
            else
            {
                <div id="offerCards" class="kh-detail-stack">
                    @foreach (var offer in offers)
                    {
                        var (offerStatusClass, offerStatusText, offerStatusIcon) = offer.Status switch
                        {
                            OfferStatus.Pending => ("kh-status-soft-warning", "Pending", "fa-clock"),
                            OfferStatus.FinalPriceSubmitted => ("kh-status-soft-blue", "Final Price Ready", "fa-tag"),
                            OfferStatus.AcceptedByCustomer => ("kh-status-soft-success", "Accepted", "fa-check"),
                            OfferStatus.RejectedByCustomer => ("kh-status-soft-danger", "Rejected", "fa-times"),
                            _ => ("kh-status-soft-muted", offer.Status.ToString(), "fa-circle")
                        };

                        <article class="kh-offer-card @(offer.Status == OfferStatus.AcceptedByCustomer ? "border-success" : "")"
                                 data-offer-card data-status="@offer.Status">
                            <div class="kh-card-topline">
                                <div class="kh-offer-provider">
                                    @if (!string.IsNullOrEmpty(offer.ProviderProfile?.ProfileImage))
                                    {
                                        <img src="@offer.ProviderProfile.ProfileImage" class="kh-avatar"
                                             alt="@offer.ProviderProfile?.User?.FirstName @offer.ProviderProfile?.User?.LastName" />
                                    }
                                    else
                                    {
                                        <span class="kh-avatar-fallback">
                                            @(offer.ProviderProfile?.User?.FirstName?.Substring(0, 1) ?? "P")
                                        </span>
                                    }
                                    <div>
                                        <a asp-area="" asp-controller="ProviderPublic" asp-action="Profile"
                                           asp-route-id="@offer.ProviderProfileId"
                                           class="fw-800 text-decoration-none text-dark">
                                            @offer.ProviderProfile?.User?.FirstName @offer.ProviderProfile?.User?.LastName
                                        </a>
                                        <div class="d-flex flex-wrap gap-2 mt-1">
                                            @if (offer.ProviderProfile?.IsVerified == true)
                                            {
                                                <span class="kh-status-badge kh-status-soft-success">
                                                    <i class="fas fa-shield-alt"></i>Verified
                                                </span>
                                            }
                                            <span class="small text-muted">
                                                <i class="fas fa-star text-warning me-1"></i>
                                                @offer.ProviderProfile?.AverageRating.ToString("0.0")
                                            </span>
                                            <span class="small text-muted">
                                                <i class="fas fa-briefcase text-primary me-1"></i>
                                                @offer.ProviderProfile?.CompletedJobsCount jobs
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <span class="kh-status-badge @offerStatusClass">
                                    <i class="fas @offerStatusIcon"></i>@offerStatusText
                                </span>
                            </div>

                            <div class="kh-price-grid">
                                <div class="kh-price-cell">
                                    <div class="small text-muted">Estimated range</div>
                                    <div class="kh-price">
                                        @offer.EstimatedMinPrice.ToString("0.##") - @offer.EstimatedMaxPrice.ToString("0.##") JD
                                    </div>
                                </div>
                                <div class="kh-price-cell">
                                    <div class="small text-muted">Final price</div>
                                    <div class="kh-price @(offer.FinalPrice.HasValue ? "" : "text-muted")">
                                        @(offer.FinalPrice.HasValue ? offer.FinalPrice.Value.ToString("0.##") + " JD" : "Waiting")
                                    </div>
                                </div>
                            </div>

                            @if (!string.IsNullOrEmpty(offer.Notes))
                            {
                                <p class="text-muted small mb-0">
                                    <i class="fas fa-comment-dots me-1 text-primary"></i>@offer.Notes
                                </p>
                            }

                            <div class="kh-card-footer">
                                <span class="text-muted small">
                                    Submitted @offer.CreatedAt.ToString("MMM dd, yyyy")
                                </span>
                                <div class="d-flex flex-wrap gap-2">
                                    <a asp-area="" asp-controller="ProviderPublic" asp-action="Profile"
                                       asp-route-id="@offer.ProviderProfileId" class="btn btn-outline-secondary btn-sm">
                                        <i class="fas fa-user me-1"></i> Profile
                                    </a>
                                    @if (offer.Status == OfferStatus.FinalPriceSubmitted &&
                                         Model.Status != ServiceRequestStatus.Confirmed &&
                                         Model.Status != ServiceRequestStatus.Completed &&
                                         Model.Status != ServiceRequestStatus.Cancelled)
                                    {
                                        <form asp-action="AcceptFinalPrice" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="offerId" value="@offer.Id" />
                                            <button type="submit" class="btn btn-success btn-sm"
                                                    onclick="return confirm('Accept this final price of @offer.FinalPrice JD?')">
                                                <i class="fas fa-check me-1"></i> Accept @offer.FinalPrice JD
                                            </button>
                                        </form>
                                        <form asp-action="RejectOffer" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="offerId" value="@offer.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm">
                                                <i class="fas fa-times me-1"></i> Reject
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </article>
                    }
                </div>

                <div id="offerFilterEmpty" class="empty-state" style="display:none;">
                    <i class="fas fa-filter"></i>
                    <h5>No offers in this status</h5>
                    <p>Choose another status to keep comparing bids.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const chips = Array.from(document.querySelectorAll('[data-offer-filter]'));
            const cards = Array.from(document.querySelectorAll('[data-offer-card]'));
            const empty = document.getElementById('offerFilterEmpty');

            if (!chips.length || !cards.length) return;

            chips.forEach(function (chip) {
                chip.addEventListener('click', function () {
                    const status = chip.dataset.offerFilter;
                    let visible = 0;

                    chips.forEach(function (item) {
                        item.classList.toggle('active', item === chip);
                    });

                    cards.forEach(function (card) {
                        const match = status === 'all' || card.dataset.status === status;
                        card.style.display = match ? '' : 'none';
                        if (match) visible += 1;
                    });

                    if (empty) {
                        empty.style.display = visible === 0 ? '' : 'none';
                    }
                });
            });
        })();
    </script>
}
