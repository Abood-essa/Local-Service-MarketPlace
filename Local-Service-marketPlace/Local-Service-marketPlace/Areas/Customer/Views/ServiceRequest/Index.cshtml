@using Local_Service_marketPlace.Models.Enums
@model IEnumerable<Local_Service_marketPlace.Models.ServiceRequest>
@{
    ViewData["Title"] = "My Requests";
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";

    var requests = Model.ToList();
    var totalRequestsCount = ViewBag.TotalRequestsCount ?? requests.Count;
    var totalOffers = ViewBag.TotalOffersCount ?? requests.Sum(r => r.Offers?.Count ?? 0);
    var activeRequests = ViewBag.ActiveRequestsCount ?? requests.Count(r => r.Status == ServiceRequestStatus.Confirmed || r.Status == ServiceRequestStatus.InProgress);
    var waitingRequests = ViewBag.WaitingRequestsCount ?? requests.Count(r => r.Status == ServiceRequestStatus.OfferReceived || r.Status == ServiceRequestStatus.WaitingForConfirmation);
    var currentStatus = ViewBag.Status as string;
}

<div class="marketplace-page">
    <section class="kh-page-hero">
        <div class="kh-hero-grid">
            <div>
                <div class="kh-hero-kicker">
                    <i class="fas fa-list-alt"></i>
                    My service requests
                </div>
                <h1 class="kh-page-title">Review requests and compare provider bids.</h1>
                <p class="kh-page-copy">
                    Keep every posted job organized from first offer through booking confirmation.
                </p>
                <div class="kh-hero-actions">
                    <a asp-action="Create" class="btn btn-primary">
                        <i class="fas fa-plus me-1"></i> New request
                    </a>
                </div>
            </div>
            <div class="kh-hero-panel">
                <div class="kh-inline-between">
                    <div>
                        <div class="kh-stat-label">Offers received</div>
                        <div class="fs-2 fw-800">@totalOffers</div>
                    </div>
                    <span class="icon-chip bg-white"><i class="fas fa-file-signature"></i></span>
                </div>
                <p class="small mb-0 mt-2 text-white-50">Open a request to compare provider bids and final prices.</p>
            </div>
        </div>
    </section>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <section class="kh-metric-grid">
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-clipboard-list"></i></span>
            <div class="kh-metric-number">@totalRequestsCount</div>
            <div class="kh-metric-label">Total requests</div>
        </article>
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-inbox"></i></span>
            <div class="kh-metric-number">@totalOffers</div>
            <div class="kh-metric-label">Offers received</div>
        </article>
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-hourglass-half"></i></span>
            <div class="kh-metric-number">@waitingRequests</div>
            <div class="kh-metric-label">Need review</div>
        </article>
        <article class="kh-metric">
            <span class="kh-metric-icon"><i class="fas fa-calendar-check"></i></span>
            <div class="kh-metric-number">@activeRequests</div>
            <div class="kh-metric-label">Booked or active</div>
        </article>
    </section>

    <section class="kh-filter-panel">
        <div class="kh-filter-title">
            <i class="fas fa-filter"></i>
            Request status
        </div>
        <form method="get" class="kh-chip-row">
            <a asp-action="Index" class="kh-filter-chip @(string.IsNullOrEmpty(currentStatus) ? "active" : "")">
                <i class="fas fa-border-all"></i> All
            </a>
            @foreach (var s in Enum.GetValues<ServiceRequestStatus>())
            {
                var icon = s switch
                {
                    ServiceRequestStatus.Pending => "fa-clock",
                    ServiceRequestStatus.OfferReceived => "fa-envelope-open",
                    ServiceRequestStatus.WaitingForConfirmation => "fa-hourglass-half",
                    ServiceRequestStatus.Confirmed => "fa-check-circle",
                    ServiceRequestStatus.InProgress => "fa-spinner",
                    ServiceRequestStatus.Completed => "fa-check-double",
                    ServiceRequestStatus.Cancelled => "fa-ban",
                    _ => "fa-circle"
                };
                <a asp-action="Index" asp-route-status="@s"
                   class="kh-filter-chip @(currentStatus == s.ToString() ? "active" : "")">
                    <i class="fas @icon"></i> @s
                </a>
            }
        </form>
    </section>

    @if (!requests.Any())
    {
        <div class="empty-state">
            <i class="fas fa-clipboard-list"></i>
            <h5>No requests yet</h5>
            <p class="mb-3">Post your first service request and get offers from providers.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus me-1"></i> Post a request
            </a>
        </div>
    }
    else
    {
        <section class="kh-card-grid">
            @foreach (var req in requests)
            {
                var (statusClass, statusIcon) = req.Status switch
                {
                    ServiceRequestStatus.Pending => ("kh-status-soft-warning", "fa-clock"),
                    ServiceRequestStatus.OfferReceived => ("kh-status-soft-blue", "fa-envelope-open"),
                    ServiceRequestStatus.WaitingForConfirmation => ("kh-status-soft-primary", "fa-hourglass-half"),
                    ServiceRequestStatus.Confirmed => ("kh-status-soft-success", "fa-check-circle"),
                    ServiceRequestStatus.InProgress => ("kh-status-soft-primary", "fa-spinner"),
                    ServiceRequestStatus.Completed => ("kh-status-soft-success", "fa-check-double"),
                    ServiceRequestStatus.Cancelled => ("kh-status-soft-danger", "fa-times-circle"),
                    _ => ("kh-status-soft-muted", "fa-question")
                };
                var offersCount = req.Offers?.Count ?? 0;

                <article class="kh-request-card">
                    <div class="kh-card-topline">
                        <span class="kh-status-badge @statusClass">
                            <i class="fas @statusIcon"></i>@req.Status
                        </span>
                        <small class="text-muted">@req.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>

                    <div>
                        <h3 class="kh-card-title">@req.Title</h3>
                        <p class="text-muted small mb-0">
                            <i class="fas fa-tag me-1 text-primary"></i>@req.Category?.Name
                        </p>
                    </div>

                    <ul class="kh-meta-list">
                        <li>
                            <i class="fas fa-location-dot"></i>
                            <span>@req.City</span>
                        </li>
                        <li>
                            <i class="fas fa-calendar-day"></i>
                            <span>@req.PreferredDate.ToString("MMM dd, yyyy")</span>
                        </li>
                    </ul>

                    <div class="kh-inline-between mt-auto">
                        <span class="kh-status-badge kh-status-soft-blue">
                            <i class="fas fa-file-alt"></i>
                            @offersCount offer@(offersCount == 1 ? "" : "s")
                        </span>
                        <a asp-action="Details" asp-route-id="@req.Id" class="btn btn-outline-primary">
                            View bids <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </article>
            }
        </section>
        
        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-5">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { status = ViewBag.Status, page = ViewBag.CurrentPage - 1 })" aria-label="Previous">
                            <span aria-hidden="true">&laquo;</span>
                        </a>
                    </li>
                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { status = ViewBag.Status, page = i })">@i</a>
                        </li>
                    }
                    <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                        <a class="page-link" href="@Url.Action("Index", new { status = ViewBag.Status, page = ViewBag.CurrentPage + 1 })" aria-label="Next">
                            <span aria-hidden="true">&raquo;</span>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
