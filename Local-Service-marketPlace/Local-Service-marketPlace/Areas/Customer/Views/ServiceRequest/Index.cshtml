@using Local_Service_marketPlace.Models.Enums
@model IEnumerable<Local_Service_marketPlace.Models.ServiceRequest>
@{
    ViewData["Title"] = "My Requests";
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-start">
    <div>
        <h2><i class="fas fa-list-alt text-primary me-2"></i>My Service Requests</h2>
        <p>Track all your posted service requests and their offers.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus me-1"></i> New Request
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="k-card mb-4 py-2">
    <form method="get" class="d-flex flex-wrap gap-2 align-items-center">
        <span class="text-muted small fw-600 me-1">Filter:</span>
        <a asp-action="Index" class="btn btn-sm @(string.IsNullOrEmpty(ViewBag.Status as string) ? "btn-primary" : "btn-outline-secondary")">
            All
        </a>
        @foreach (var s in Enum.GetValues<ServiceRequestStatus>())
        {
            <a asp-action="Index" asp-route-status="@s"
               class="btn btn-sm @(ViewBag.Status == s.ToString() ? "btn-primary" : "btn-outline-secondary")">
                @s
            </a>
        }
    </form>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <i class="fas fa-clipboard-list"></i>
        <h5>No requests yet</h5>
        <p class="mb-3">Post your first service request and get offers from providers.</p>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> Post a Request
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var req in Model)
        {
            
                var (badgeCss, icon) = req.Status switch
                {
                    ServiceRequestStatus.Pending              => ("bg-warning text-dark", "fa-clock"),
                    ServiceRequestStatus.OfferReceived        => ("bg-info text-dark", "fa-envelope-open"),
                    ServiceRequestStatus.WaitingForConfirmation => ("bg-primary", "fa-hourglass-half"),
                    ServiceRequestStatus.Confirmed            => ("bg-success", "fa-check-circle"),
                    ServiceRequestStatus.InProgress           => ("bg-primary", "fa-spinner"),
                    ServiceRequestStatus.Completed            => ("bg-success", "fa-check-double"),
                    ServiceRequestStatus.Cancelled            => ("bg-danger", "fa-times-circle"),
                    _                                         => ("bg-secondary", "fa-question")
                };
                var offersCount = req.Offers?.Count ?? 0;
            
            <div class="col-md-6 col-lg-4">
                <div class="k-card h-100">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge @badgeCss badge-status">
                            <i class="fas @icon me-1"></i>@req.Status
                        </span>
                        <small class="text-muted">@req.CreatedAt.ToString("MMM dd, yyyy")</small>
                    </div>

                    <h6 class="fw-700 mb-1">@req.Title</h6>
                    <p class="text-muted small mb-2">
                        <i class="fas fa-tag me-1"></i>@req.Category?.Name
                    </p>
                    <p class="text-muted small mb-3">
                        <i class="fas fa-map-marker-alt me-1"></i>@req.City
                        &nbsp;·&nbsp;
                        <i class="fas fa-calendar me-1"></i>@req.PreferredDate.ToString("MMM dd")
                    </p>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="small text-muted">
                            <i class="fas fa-file-alt me-1"></i>
                            <strong>@offersCount</strong> offer@(offersCount != 1 ? "s" : "")
                        </span>
                        <a asp-action="Details" asp-route-id="@req.Id"
                           class="btn btn-sm btn-outline-primary">
                            View Details <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
