@using Microsoft.AspNetCore.Identity
@using Local_Service_marketPlace.Data
@using Microsoft.EntityFrameworkCore
@inject SignInManager<Local_Service_marketPlace.Models.ApplicationUser> SignInManager
@inject UserManager<Local_Service_marketPlace.Models.ApplicationUser> UserManager
@inject ApplicationDbContext DbContext

@{
    var currentUserId = UserManager.GetUserId(User);
    var unreadCount = await DbContext.Notifications
        .CountAsync(n => n.UserId == currentUserId && !n.IsRead);
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Khidmati</title>
    <script>
        (function () {
            const savedTheme = localStorage.getItem('khidmati-theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else {
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
            }
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/khidmati-theme.css" asp-append-version="true" />
</head>
<body class="app-shell customer-shell">
    <nav class="app-navbar">
        <div class="container app-nav-container">
            <a asp-area="Customer" asp-controller="ServiceRequest" asp-action="Index" class="brand-mark">Khid<span>mati</span></a>

            <div class="app-nav-links">
                <a asp-area="Customer" asp-controller="ServiceRequest" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "ServiceRequest" ? "active" : "")">
                    <i class="fas fa-list-alt"></i> My Requests
                </a>
                <a asp-area="Customer" asp-controller="ServiceRequest" asp-action="Create" class="nav-link-custom">
                    <i class="fas fa-plus-circle"></i> New Request
                </a>
                <a asp-area="Customer" asp-controller="Booking" asp-action="Index"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Booking" ? "active" : "")">
                    <i class="fas fa-calendar-check"></i> My Bookings
                </a>
                <a asp-area="Customer" asp-controller="Complaint" asp-action="MyComplaints"
                   class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Complaint" ? "active" : "")">
                    <i class="fas fa-flag"></i> My Complaints
                </a>
            </div>

            <div class="app-nav-actions">
                <button type="button" class="notif-bell theme-toggle border-0" aria-label="Toggle theme" style="cursor: pointer; outline: none;">
                    <i class="fa-solid fa-moon"></i>
                </button>
                <a asp-area="Customer" asp-controller="Notification" asp-action="Index" class="notif-bell" aria-label="Notifications">
                    <i class="fas fa-bell"></i>
                    @if (unreadCount > 0)
                    {
                        <span class="notif-badge" id="notif-badge">@(unreadCount > 9 ? "9+" : unreadCount.ToString())</span>
                    }
                </a>
                <span class="text-muted small"><i class="fas fa-user-circle me-1"></i>@User.Identity?.Name</span>
                <a asp-area="" asp-controller="Account" asp-action="Logout" class="btn-logout">
                    <i class="fas fa-sign-out-alt me-1"></i> Logout
                </a>
            </div>
        </div>
    </nav>

    <div class="page-wrapper">
        <div class="container">@RenderBody()</div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>



    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Success"]',
                confirmButtonColor: '#b86048'
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["Error"]',
                confirmButtonColor: '#d33'
            });
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>
            Swal.fire({
                icon: 'info',
                title: 'Info',
                text: '@TempData["Info"]',
                confirmButtonColor: '#4a3729'
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
