@model Local_Service_marketPlace.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4">

    <!-- Row 1: Core Counts -->
    <div class="row g-4">

        <!-- Users -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-users fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Total Users</p>
                    <h6 class="mb-0">@Model.TotalUsers</h6>
                </div>
            </div>
        </div>

        <!-- Total Providers -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-user-tie fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Total Providers</p>
                    <h6 class="mb-0">@Model.TotalProviders</h6>
                </div>
            </div>
        </div>

        <!-- Verified Providers -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-user-check fa-3x text-success"></i>
                <div class="ms-3">
                    <p class="mb-2">Verified Providers</p>
                    <h6 class="mb-0">@Model.VerifiedProviders</h6>
                </div>
            </div>
        </div>

        <!-- Pending Verification -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-user-clock fa-3x text-warning"></i>
                <div class="ms-3">
                    <p class="mb-2">Pending Verification</p>
                    <h6 class="mb-0">@Model.PendingVerification</h6>
                </div>
            </div>
        </div>

    </div>

    <!-- Row 2: Requests & Bookings -->
    <div class="row g-4 mt-1">

        <!-- Total Requests -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-list fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Total Requests</p>
                    <h6 class="mb-0">@Model.TotalRequests</h6>
                </div>
            </div>
        </div>

        <!-- Total Bookings -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-calendar-check fa-3x text-primary"></i>
                <div class="ms-3">
                    <p class="mb-2">Total Bookings</p>
                    <h6 class="mb-0">@Model.TotalBookings</h6>
                </div>
            </div>
        </div>

        <!-- Active Bookings -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-spinner fa-3x text-info"></i>
                <div class="ms-3">
                    <p class="mb-2">Active Bookings</p>
                    <h6 class="mb-0">@Model.ActiveBookings</h6>
                </div>
            </div>
        </div>

        <!-- Completed Bookings -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-check-circle fa-3x text-success"></i>
                <div class="ms-3">
                    <p class="mb-2">Completed Bookings</p>
                    <h6 class="mb-0">@Model.CompletedBookings</h6>
                </div>
            </div>
        </div>

    </div>

    <!-- Row 3: Financial & Complaints -->
    <div class="row g-4 mt-1">

        <!-- Total Revenue -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded p-4">
                <p class="mb-2">Total Revenue</p>
                <h4 class="text-success mb-0">@Model.TotalRevenue JD</h4>
            </div>
        </div>

        <!-- Wallet Commissions -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded p-4">
                <p class="mb-2">Wallet Commissions</p>
                <h4 class="text-success mb-0">@Model.TotalWalletCommissions JD</h4>
            </div>
        </div>

        <!-- Providers in Debt -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded p-4">
                <p class="mb-2">Providers in Debt</p>
                <h4 class="text-danger mb-0">
                    @Model.ProvidersInDebt
                    <span class="fs-6 text-muted ms-1">(@Model.TotalNegativeBalances JD)</span>
                </h4>
            </div>
        </div>

        <!-- Pending Complaints -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded p-4">
                <p class="mb-2">Pending Complaints</p>
                <h4 class="text-danger mb-0">@Model.PendingComplaints</h4>
            </div>
        </div>

    </div>

    <!-- Latest Service Requests -->
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="bg-secondary rounded p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0">Latest Service Requests</h5>
                </div>

                <div class="table-responsive">
                    <table class="table text-start align-middle table-bordered table-hover mb-0">
                        <thead>
                            <tr class="text-white">
                                <th>Title</th>
                                <th>Customer</th>
                                <th>City</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.LatestRequests)
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.Customer.FirstName @item.Customer.LastName</td>
                                    <td>@item.City</td>
                                    <td>
                                        <span class="badge bg-warning">@item.Status</span>
                                    </td>
                                    <td>@item.CreatedAt.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

    <!-- Latest Bookings -->
    <div class="row g-4 mt-1">
        <div class="col-12">
            <div class="bg-secondary rounded p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0">Latest Bookings</h5>
                </div>

                <div class="table-responsive">
                    <table class="table text-start align-middle table-bordered table-hover mb-0">
                        <thead>
                            <tr class="text-white">
                                <th>Customer</th>
                                <th>Provider</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.LatestBookings)
                            {
                                <tr>
                                    <td>@item.Customer.FirstName @item.Customer.LastName</td>
                                    <td>@item.ProviderProfile.User.FirstName @item.ProviderProfile.User.LastName</td>
                                    <td>@item.FinalConfirmedPrice JD</td>
                                    <td>
                                        <span class="badge bg-success">@item.BookingStatus</span>
                                    </td>
                                    <td>@item.CreatedAt.ToShortDateString()</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </div>

</div>
