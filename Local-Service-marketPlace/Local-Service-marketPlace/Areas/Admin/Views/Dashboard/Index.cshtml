@model Local_Service_marketPlace.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml"; 
}




<div class="container-fluid pt-4 px-4">

    <!-- Statistics Cards -->
    <div class="row g-4">

        <!-- Users -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-users fa-3x text-primary"></i>

                <div class="ms-3">
                    <p class="mb-2">Users</p>
                    <h6 class="mb-0">@Model.TotalUsers</h6>
                </div>
            </div>
        </div>

        <!-- Providers -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-user-tie fa-3x text-primary"></i>

                <div class="ms-3">
                    <p class="mb-2">Providers</p>
                    <h6 class="mb-0">@Model.TotalProviders</h6>
                </div>
            </div>
        </div>

        <!-- Requests -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-list fa-3x text-primary"></i>

                <div class="ms-3">
                    <p class="mb-2">Requests</p>
                    <h6 class="mb-0">@Model.TotalRequests</h6>
                </div>
            </div>
        </div>

        <!-- Bookings -->
        <div class="col-sm-6 col-xl-3">
            <div class="bg-secondary rounded d-flex align-items-center justify-content-between p-4">
                <i class="fa fa-calendar-check fa-3x text-primary"></i>

                <div class="ms-3">
                    <p class="mb-2">Bookings</p>
                    <h6 class="mb-0">@Model.TotalBookings</h6>
                </div>
            </div>
        </div>

    </div>

    <!-- Revenue + Complaints -->
    <div class="row g-4 mt-1">

        <!-- Revenue -->
        <div class="col-md-6">
            <div class="bg-secondary rounded p-4">
                <h5>Total Revenue</h5>

                <h2 class="text-success mt-3">
                    @Model.TotalRevenue JD
                </h2>
            </div>
        </div>

        <!-- Complaints -->
        <div class="col-md-6">
            <div class="bg-secondary rounded p-4">
                <h5>Pending Complaints</h5>

                <h2 class="text-danger mt-3">
                    @Model.PendingComplaints
                </h2>
            </div>
        </div>

    </div>

    <!-- Latest Requests -->
    <div class="row g-4 mt-1">

        <div class="col-12">
            <div class="bg-secondary rounded p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0">Latest Service Requests</h5>
                </div>

                <div class="table-responsive">
                    <table class="table text-start align-middle table-bordered table-hover mb-0">

                        <thead>
                            <tr class="text-white">
                                <th>Title</th>
                                <th>Customer</th>
                                <th>City</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model.LatestRequests)
                            {
                                <tr>

                                    <td>@item.Title</td>

                                    <td>
                                        @item.Customer.FirstName
                                        @item.Customer.LastName
                                    </td>

                                    <td>@item.City</td>

                                    <td>
                                        <span class="badge bg-warning">
                                            @item.Status
                                        </span>
                                    </td>

                                    <td>
                                        @item.CreatedAt.ToShortDateString()
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                </div>

            </div>
        </div>

    </div>

    <!-- Latest Bookings -->
    <div class="row g-4 mt-1">

        <div class="col-12">
            <div class="bg-secondary rounded p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0">Latest Bookings</h5>
                </div>

                <div class="table-responsive">

                    <table class="table text-start align-middle table-bordered table-hover mb-0">

                        <thead>
                            <tr class="text-white">
                                <th>Customer</th>
                                <th>Provider</th>
                                <th>Price</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model.LatestBookings)
                            {
                                <tr>

                                    <td>
                                        @item.Customer.FirstName
                                        @item.Customer.LastName
                                    </td>

                                    <td>
                                        @item.ProviderProfile.User.FirstName
                                        @item.ProviderProfile.User.LastName
                                    </td>

                                    <td>
                                        @item.FinalConfirmedPrice JD
                                    </td>

                                    <td>
                                        <span class="badge bg-success">
                                            @item.BookingStatus
                                        </span>
                                    </td>

                                    <td>
                                        @item.CreatedAt.ToShortDateString()
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>
        </div>

    </div>

</div>