<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - Khidmati Admin</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">

    <script>
        (function () {
            const savedTheme = localStorage.getItem('khidmati-theme');
            if (savedTheme) {
                document.documentElement.setAttribute('data-theme', savedTheme);
            } else {
                const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
                document.documentElement.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
            }
        })();
    </script>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/admin/lib/owlcarousel/assets/owl.carousel.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/admin/lib/tempusdominus/css/tempusdominus-bootstrap-4.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/admin/css/bootstrap.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/admin/css/style.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/khidmati-theme.css" asp-append-version="true">
</head>
<body class="admin-shell">
    <div class="container-fluid position-relative d-flex p-0">
        <div id="spinner" class="show position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
            <div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status">
                <span class="sr-only">Loading...</span>
            </div>
        </div>

        <partial name="~/Areas/Admin/Views/Shared/_AdminSidebar.cshtml" />

        <div class="content">
            <partial name="~/Areas/Admin/Views/Shared/_AdminNavbar.cshtml" />

            @RenderBody()

            <div class="container-fluid pt-4 px-4">
                <div class="bg-secondary rounded-top p-4">
                    <div class="row">
                        <div class="col-12 col-sm-6 text-center text-sm-start">
                            &copy; <a href="#">Khidmati</a>, All Rights Reserved.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <a href="#" class="btn btn-lg btn-primary btn-lg-square back-to-top"><i class="bi bi-arrow-up"></i></a>

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/admin/lib/chart/chart.min.js" asp-append-version="true"></script>
    <script src="~/admin/lib/easing/easing.min.js" asp-append-version="true"></script>
    <script src="~/admin/lib/waypoints/waypoints.min.js" asp-append-version="true"></script>
    <script src="~/admin/lib/owlcarousel/owl.carousel.min.js" asp-append-version="true"></script>
    <script src="~/admin/lib/tempusdominus/js/moment.min.js" asp-append-version="true"></script>
    <script src="~/admin/lib/tempusdominus/js/moment-timezone.min.js" asp-append-version="true"></script>
    <script src="~/admin/lib/tempusdominus/js/tempusdominus-bootstrap-4.min.js" asp-append-version="true"></script>
    <script src="~/admin/js/main.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            Swal.fire({
                icon: 'success',
                title: 'Success',
                text: '@TempData["Success"]',
                confirmButtonColor: '#b86048'
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <script>
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: '@TempData["Error"]',
                confirmButtonColor: '#d33'
            });
        </script>
    }

    @if (TempData["Info"] != null)
    {
        <script>
            Swal.fire({
                icon: 'info',
                title: 'Info',
                text: '@TempData["Info"]',
                confirmButtonColor: '#4a3729'
            });
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
