@model Local_Service_marketPlace.Models.Complaint
@using Local_Service_marketPlace.Models.Enums
@{
    ViewData["Title"] = "Complaint Details";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4">

    <!-- Page Header -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <i class="fa fa-exclamation-circle fa-2x text-primary me-3"></i>
            <h4 class="mb-0">Complaint #@Model.Id</h4>
        </div>
        <a asp-area="Admin" asp-controller="Complaint" asp-action="Index"
           class="btn btn-outline-secondary btn-sm">
            <i class="fa fa-arrow-left me-1"></i>Back to List
        </a>
    </div>

    <!-- Success Message -->
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">

        <!-- Left Column: Complaint Info + Booking Info -->
        <div class="col-lg-7">

            <!-- Complaint Details -->
            <div class="bg-secondary rounded p-4 mb-4">
                <h5 class="mb-4">
                    <i class="fa fa-flag me-2 text-danger"></i>Complaint Details
                </h5>

                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr>
                            <td class="text-muted" style="width: 160px;">Status</td>
                            <td>
                                @switch (Model.Status)
                                {
                                    case ComplaintStatus.Open:
                                        <span class="badge bg-danger">Open</span>
                                        break;
                                    case ComplaintStatus.UnderReview:
                                        <span class="badge bg-warning">Under Review</span>
                                        break;
                                    case ComplaintStatus.Resolved:
                                        <span class="badge bg-success">Resolved</span>
                                        break;
                                    case ComplaintStatus.Dismissed:
                                        <span class="badge bg-secondary">Dismissed</span>
                                        break;
                                }
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Reported By</td>
                            <td>
                                @Model.ReportedByUser.FirstName @Model.ReportedByUser.LastName
                                <small class="text-muted ms-1">(@Model.ReportedByUser.Email)</small>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">Filed On</td>
                            <td>@Model.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")</td>
                        </tr>
                        @if (Model.ResolvedAt.HasValue)
                        {
                            <tr>
                                <td class="text-muted">Resolved On</td>
                                <td>@Model.ResolvedAt.Value.ToString("dd MMM yyyy, hh:mm tt")</td>
                            </tr>
                        }
                        <tr>
                            <td class="text-muted">Reason</td>
                            <td><strong>@Model.Reason</strong></td>
                        </tr>
                        <tr>
                            <td class="text-muted">Description</td>
                            <td>@Model.Description</td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(Model.AdminNotes))
                        {
                            <tr>
                                <td class="text-muted">Admin Notes</td>
                                <td class="text-warning">@Model.AdminNotes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Booking Info -->
            <div class="bg-secondary rounded p-4">
                <h5 class="mb-4">
                    <i class="fa fa-calendar-check me-2 text-primary"></i>Related Booking
                </h5>

                @if (Model.Booking != null)
                {
                    <table class="table table-borderless mb-0">
                        <tbody>
                            <tr>
                                <td class="text-muted" style="width: 160px;">Booking #</td>
                                <td>@Model.Booking.Id</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Service</td>
                                <td>@(Model.Booking.ServiceRequest?.Title ?? "—")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Customer</td>
                                <td>@Model.Booking.Customer.FirstName @Model.Booking.Customer.LastName</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Provider</td>
                                <td>@Model.Booking.ProviderProfile.User.FirstName @Model.Booking.ProviderProfile.User.LastName</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Price</td>
                                <td>@Model.Booking.FinalConfirmedPrice JD</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Booking Status</td>
                                <td>
                                    <span class="badge bg-info">@Model.Booking.BookingStatus</span>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-muted">Booking Date</td>
                                <td>@Model.Booking.CreatedAt.ToShortDateString()</td>
                            </tr>
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0">Booking information not available.</p>
                }
            </div>

        </div>

        <!-- Right Column: Admin Action Panel -->
        <div class="col-lg-5">
            <div class="bg-secondary rounded p-4">
                <h5 class="mb-4">
                    <i class="fa fa-tools me-2 text-warning"></i>Admin Actions
                </h5>

                <form asp-area="Admin" asp-controller="Complaint"
                      asp-action="UpdateStatus" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.Id" />

                    <!-- Status -->
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="status" class="form-select bg-dark text-white border-secondary">
                            @foreach (ComplaintStatus s in Enum.GetValues(typeof(ComplaintStatus)))
                            {
                                if (s == Model.Status)
                                {
                                    <option value="@s" selected>@s</option>
                                }
                                else
                                {
                                    <option value="@s">@s</option>
                                }
                            }
                        </select>
                    </div>

                    <!-- Admin Notes -->
                    <div class="mb-4">
                        <label class="form-label">Admin Notes</label>
                        <textarea name="adminNotes" rows="5"
                                  class="form-control bg-dark text-white border-secondary"
                                  placeholder="Add internal notes about this complaint...">@Model.AdminNotes</textarea>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fa fa-save me-2"></i>Save Changes
                    </button>
                </form>

                <!-- Quick Status Shortcuts -->
                <hr class="border-secondary mt-4" />
                <p class="text-muted small mb-3">Quick Actions</p>
                <div class="d-flex gap-2 flex-wrap">

                    <form asp-area="Admin" asp-controller="Complaint"
                          asp-action="UpdateStatus" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="@ComplaintStatus.UnderReview" />
                        <input type="hidden" name="adminNotes" value="@Model.AdminNotes" />
                        <button type="submit" class="btn btn-sm btn-outline-warning"
                                @(Model.Status == ComplaintStatus.UnderReview ? "disabled" : "")>
                            <i class="fa fa-search me-1"></i>Mark Under Review
                        </button>
                    </form>

                    <form asp-area="Admin" asp-controller="Complaint"
                          asp-action="UpdateStatus" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="@ComplaintStatus.Resolved" />
                        <input type="hidden" name="adminNotes" value="@Model.AdminNotes" />
                        <button type="submit" class="btn btn-sm btn-outline-success"
                                @(Model.Status == ComplaintStatus.Resolved ? "disabled" : "")>
                            <i class="fa fa-check me-1"></i>Mark Resolved
                        </button>
                    </form>

                    <form asp-area="Admin" asp-controller="Complaint"
                          asp-action="UpdateStatus" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="@ComplaintStatus.Dismissed" />
                        <input type="hidden" name="adminNotes" value="@Model.AdminNotes" />
                        <button type="submit" class="btn btn-sm btn-outline-secondary"
                                @(Model.Status == ComplaintStatus.Dismissed ? "disabled" : "")>
                            <i class="fa fa-ban me-1"></i>Dismiss
                        </button>
                    </form>

                </div>
            </div>
        </div>

    </div>

</div>
