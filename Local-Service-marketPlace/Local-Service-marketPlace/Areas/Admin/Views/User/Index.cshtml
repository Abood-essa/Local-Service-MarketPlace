@using Microsoft.AspNetCore.Identity
@model IEnumerable<Local_Service_marketPlace.Models.ApplicationUser>
@inject UserManager<Local_Service_marketPlace.Models.ApplicationUser> UserManager
@inject Local_Service_marketPlace.Data.ApplicationDbContext Db
@{
    ViewData["Title"] = "Users";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-secondary text-center rounded p-4">

        <h4 class="mb-4">System Users</h4>

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show text-start">
                <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show text-start">
                <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="p-3 mb-4 rounded text-start" style="background-color: var(--kh-surface-low); border: 1px solid var(--kh-outline);">
            <div class="row g-2">
                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted" style="border-color: var(--kh-outline);">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" id="userSearchInput" class="form-control border-start-0 ps-0" placeholder="Search by name, email, phone..." />
                    </div>
                </div>
                <div class="col-6 col-md-3">
                    <select id="userRoleFilter" class="form-select">
                        <option value="">All Roles</option>
                        <option value="Admin">Admin</option>
                        <option value="Provider">Provider</option>
                        <option value="Customer">Customer</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <select id="userStatusFilter" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="Active">Active</option>
                        <option value="Deactivated">Deactivated</option>
                    </select>
                </div>
                <div class="col-12 col-md-2">
                    <select id="userVerificationFilter" class="form-select">
                        <option value="">Verification</option>
                        <option value="Verified">Verified</option>
                        <option value="Pending">Pending</option>
                        <option value="No Profile Yet">No Profile</option>
                        <option value="N/A">N/A</option>
                    </select>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table id="users-table" class="table text-start align-middle table-bordered table-hover mb-0">
                <thead>
                    <tr class="text-white">
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Verification</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var roles = await UserManager.GetRolesAsync(user);
                        var isProvider = roles.Contains("Provider");

                        Local_Service_marketPlace.Models.ProviderProfile? profile = null;
                        if (isProvider)
                            profile = Db.ProviderProfiles.FirstOrDefault(p => p.UserId == user.Id);

                        var verificationState = !isProvider ? "N/A" : (profile == null ? "No Profile Yet" : (profile.IsVerified ? "Verified" : "Pending"));

                        <tr class="user-row"
                            data-name="@(($"{user.FirstName} {user.LastName}").ToLower())"
                            data-email="@(user.Email?.ToLower())"
                            data-phone="@(user.PhoneNumber ?? "")"
                            data-roles="@(string.Join(",", roles))"
                            data-status="@(user.IsActive ? "Active" : "Deactivated")"
                            data-verification="@verificationState">
                            <td class="fw-600">@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>@user.PhoneNumber</td>
                            <td>
                                @foreach (var role in roles)
                                {
                                    var roleBadge = role switch
                                    {
                                        "Admin" => "bg-danger",
                                        "Provider" => "bg-primary",
                                        "Customer" => "bg-success",
                                        _ => "bg-secondary"
                                    };
                                    <span class="badge @roleBadge">@role</span>
                                }
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Deactivated</span>
                                }
                            </td>
                            <td>
                                @if (!isProvider)
                                {
                                    <span class="text-muted small">N/A</span>
                                }
                                else if (profile == null)
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-clock me-1"></i>No Profile Yet
                                    </span>
                                }
                                else if (profile.IsVerified)
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-shield-alt me-1"></i>Verified
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-hourglass-half me-1"></i>Pending
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 flex-wrap">

                                    @* Activate / Deactivate *@
                                    <form asp-action="ToggleStatus" asp-route-id="@user.Id"
                                          method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit"
                                                class="btn btn-sm @(user.IsActive ? "btn-outline-danger" : "btn-outline-success")"
                                                data-confirm="@(user.IsActive ? "Deactivate" : "Activate") this user?">
                                            @(user.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </form>

                                    @* Verify / Revoke — only for providers with a profile *@
                                    @if (isProvider && profile != null)
                                    {
                                        <form asp-action="ToggleVerification" asp-route-id="@user.Id"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm @(profile.IsVerified ? "btn-outline-warning" : "btn-outline-primary")"
                                                    data-confirm="@(profile.IsVerified ? "Revoke verification for" : "Verify") this provider?">
                                                <i class="fas fa-@(profile.IsVerified ? "times" : "shield-alt") me-1"></i>
                                                @(profile.IsVerified ? "Revoke" : "Verify")
                                            </button>
                                        </form>
                                    }

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>
