@model IEnumerable<Local_Service_marketPlace.Models.ServiceRequest>
@using Local_Service_marketPlace.Models.Enums

@{
    ViewData["Title"] = "Service Requests";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-secondary text-center rounded p-4">
        <h4 class="mb-4">Service Requests Management</h4>
        <div class="p-3 mb-4 rounded text-start" style="background-color: var(--kh-surface-low); border: 1px solid var(--kh-outline);">
            <div class="row g-2">
                <div class="col-12 col-md-3">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0 text-muted" style="border-color: var(--kh-outline);">
                            <i class="fas fa-search"></i>
                        </span>
                        <input type="text" id="requestSearchInput" class="form-control border-start-0 ps-0" placeholder="Search customer, title, city..." />
                    </div>
                </div>
                <div class="col-6 col-md-2">
                    <select id="requestCategoryFilter" class="form-select">
                        <option value="">All Categories</option>
                    </select>
                </div>
                <div class="col-6 col-md-3">
                    <select id="requestStatusFilter" class="form-select">
                        <option value="">All Statuses</option>
                        <option value="Pending">Pending</option>
                        <option value="OfferReceived">OfferReceived</option>
                        <option value="WaitingForConfirmation">WaitingForConfirmation</option>
                        <option value="Confirmed">Confirmed</option>
                        <option value="InProgress">InProgress</option>
                        <option value="Completed">Completed</option>
                        <option value="Cancelled">Cancelled</option>
                    </select>
                </div>
                <div class="col-6 col-md-2">
                    <input type="number" id="requestMinPrice" class="form-control" placeholder="Min Price ($)" />
                </div>
                <div class="col-6 col-md-2">
                    <input type="number" id="requestMaxPrice" class="form-control" placeholder="Max Price ($)" />
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table id="requests-table" class="table text-start align-middle table-bordered table-hover mb-0">
                <thead>
                    <tr class="text-white">
                        <th>#</th>
                        <th>Customer</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>City</th>
                        <th>Price / Est.</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        decimal? rowMinPrice = null;
                        decimal? rowMaxPrice = null;
                        if (item.Booking != null)
                        {
                            rowMinPrice = item.Booking.FinalConfirmedPrice;
                            rowMaxPrice = item.Booking.FinalConfirmedPrice;
                        }
                        else if (item.Offers != null && item.Offers.Any())
                        {
                            rowMinPrice = item.Offers.Min(o => o.EstimatedMinPrice);
                            rowMaxPrice = item.Offers.Max(o => o.EstimatedMaxPrice);
                        }

                        <tr class="request-row"
                            data-customer="@(($"{item.Customer.FirstName} {item.Customer.LastName}").ToLower())"
                            data-title="@(item.Title.ToLower())"
                            data-city="@(item.City.ToLower())"
                            data-category="@item.Category.Name"
                            data-status="@item.Status.ToString()"
                            data-price-min="@(rowMinPrice?.ToString("0.00") ?? "")"
                            data-price-max="@(rowMaxPrice?.ToString("0.00") ?? "")">
                            <td>@item.Id</td>
                            <td>@item.Customer.FirstName @item.Customer.LastName</td>
                            <td>@item.Title</td>
                            <td>@item.Category.Name</td>
                            <td>@item.City</td>
                            <td>
                                @if (item.Booking != null)
                                {
                                    <span class="badge bg-success">
                                        Confirmed: $@item.Booking.FinalConfirmedPrice.ToString("F2")
                                    </span>
                                }
                                else if (item.Offers != null && item.Offers.Any())
                                {
                                    <span class="text-primary fw-600">
                                        Est: $@rowMinPrice?.ToString("0") - $@rowMaxPrice?.ToString("0")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">No Offers</span>
                                }
                            </td>
                            <td>
                                @{
                                    var badge = item.Status switch
                                    {
                                        ServiceRequestStatus.Pending => "bg-warning text-dark",
                                        ServiceRequestStatus.OfferReceived => "bg-info",
                                        ServiceRequestStatus.WaitingForConfirmation => "bg-primary",
                                        ServiceRequestStatus.Confirmed => "bg-primary",
                                        ServiceRequestStatus.InProgress => "bg-warning",
                                        ServiceRequestStatus.Completed => "bg-success",
                                        ServiceRequestStatus.Cancelled => "bg-danger",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @badge">@item.Status</span>
                            </td>
                            <td>@item.CreatedAt.ToShortDateString()</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-primary">
                                    <i class="fas fa-eye me-1"></i> View
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id"
                                      method="post" class="d-inline"
                                      data-confirm="Delete this request?">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-danger">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>