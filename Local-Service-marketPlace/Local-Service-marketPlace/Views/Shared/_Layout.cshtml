<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Khidmati</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/khidmati-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Local_Service_marketPlace.styles.css" asp-append-version="true" />
</head>
<body class="khidmati-public">
    <header class="public-navbar">
        <nav class="container public-nav" aria-label="Main navigation">
            <a class="brand-mark" asp-area="" asp-controller="Home" asp-action="Index">Khid<span>mati</span></a>

            <div class="public-nav-links">
                <a class="public-nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-house"></i> Home
                </a>
                <a class="public-nav-link" href="/#categories">
                    <i class="fa-solid fa-layer-group"></i> Categories
                </a>
                <a class="public-nav-link" href="/#how-it-works">
                    <i class="fa-solid fa-route"></i> How it works
                </a>
                <a class="public-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">
                    <i class="fa-solid fa-shield-halved"></i> Privacy
                </a>
            </div>

            <partial name="_LoginPartial" />
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="section-band section-band-soft py-4">
        <div class="container">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
                <a class="brand-mark" asp-area="" asp-controller="Home" asp-action="Index">Khid<span>mati</span></a>
                <div class="text-muted small">
                    &copy; 2026 Khidmati. Local service marketplace.
                </div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="public-nav-link p-0">Privacy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
