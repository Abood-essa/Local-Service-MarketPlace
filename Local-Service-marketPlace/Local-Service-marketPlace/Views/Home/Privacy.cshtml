@{
    ViewData["Title"] = "Privacy Policy";
}

<section class="section-band">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="k-card">
                    <div class="eyebrow">
                        <i class="fa-solid fa-shield-halved"></i>
                        Privacy
                    </div>
                    <h1 class="fw-800 mb-3">@ViewData["Title"]</h1>
                    <p class="text-muted mb-0">
                        Khidmati keeps account, service request, booking, payment, and verification details inside the
                        workflows where they are needed. This page can be extended with your full privacy policy when
                        the product copy is ready.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>
