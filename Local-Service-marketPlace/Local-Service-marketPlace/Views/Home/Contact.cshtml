@model Local_Service_marketPlace.Models.ViewModels.ContactViewModel
@{
    ViewData["Title"] = "Contact Us";
}

<section class="section-band pt-5 pb-5">
    <div class="container">
        <div class="row justify-content-center mb-5 text-center">
            <div class="col-lg-8">
                <div class="eyebrow justify-content-center">
                    <i class="fa-solid fa-paper-plane text-primary"></i>
                    Get in touch
                </div>
                <h1 class="fw-800 display-5 mb-3">We'd love to hear from you</h1>
                <p class="text-muted lead mb-0">
                    Have questions about services, bookings, or provider registration? Our team is here to help.
                </p>
            </div>
        </div>

        <div class="row g-4">
            <!-- Contact info cards -->
            <div class="col-lg-4">
                <div class="d-flex flex-column gap-3 h-100">
                    <div class="k-card h-100 p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="btn btn-outline-primary btn-square rounded-circle flex-shrink-0" style="width: 50px; height: 50px; pointer-events: none; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-map-location-dot"></i>
                            </div>
                            <div>
                                <h5 class="mb-1 fw-700">Office Location</h5>
                                <span class="text-muted small">Visit us in person</span>
                            </div>
                        </div>
                        <p class="text-muted mb-0">
                            123 Service Center St., Suite 400<br/>
                            Amman, Jordan
                        </p>
                    </div>

                    <div class="k-card h-100 p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="btn btn-outline-primary btn-square rounded-circle flex-shrink-0" style="width: 50px; height: 50px; pointer-events: none; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-headset"></i>
                            </div>
                            <div>
                                <h5 class="mb-1 fw-700">Contact Support</h5>
                                <span class="text-muted small">Always here to help</span>
                            </div>
                        </div>
                        <p class="text-muted mb-0">
                            <strong>Support Email:</strong> <a href="mailto:support@khidmati.com" class="text-decoration-none">support@khidmati.com</a><br/>
                            <strong>Hotline:</strong> <a href="tel:+96261234567" class="text-decoration-none">+962 6 123 4567</a>
                        </p>
                    </div>

                    <div class="k-card h-100 p-4">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="btn btn-outline-primary btn-square rounded-circle flex-shrink-0" style="width: 50px; height: 50px; pointer-events: none; display: flex; align-items: center; justify-content: center;">
                                <i class="fa-solid fa-clock"></i>
                            </div>
                            <div>
                                <h5 class="mb-1 fw-700">Working Hours</h5>
                                <span class="text-muted small">Standard timings</span>
                            </div>
                        </div>
                        <p class="text-muted mb-0">
                            Sunday - Thursday: 9:00 AM - 6:00 PM<br/>
                            Friday & Saturday: Closed
                        </p>
                    </div>
                </div>
            </div>

            <!-- Contact form -->
            <div class="col-lg-8">
                <div class="k-card p-4 p-md-5 h-100">
                    <h3 class="fw-800 mb-4">Send a Message</h3>
                    
                    <form asp-action="Contact" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()
                        
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label"></label>
                                <input asp-for="Name" class="form-control" placeholder="Your full name" required />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" type="email" class="form-control" placeholder="you@example.com" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-3">
                            <label asp-for="Subject" class="form-label"></label>
                            <input asp-for="Subject" class="form-control" placeholder="What is this about?" required />
                            <span asp-validation-for="Subject" class="text-danger small"></span>
                        </div>

                        <div class="mt-3">
                            <label asp-for="Message" class="form-label"></label>
                            <textarea asp-for="Message" class="form-control" rows="5" placeholder="Write your message here..." required></textarea>
                            <span asp-validation-for="Message" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary px-4 py-3 mt-4">
                            <i class="fa-solid fa-paper-plane me-2"></i>Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}
