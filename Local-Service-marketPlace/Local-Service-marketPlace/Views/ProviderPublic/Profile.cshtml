@using Local_Service_marketPlace.Models
@using Local_Service_marketPlace.Models.Enums
@model Local_Service_marketPlace.Models.ProviderProfile
@{
    ViewData["Title"] = "Provider Profile";
    Layout = "~/Areas/Customer/Views/Shared/_CustomerLayout.cshtml";
    bool isHidden = ViewBag.IsHidden;

    var categories = Model.ProviderCategories ?? new List<ProviderCategory>();
    var completedBookings = Model.Bookings?
        .Where(b => b.BookingStatus == BookingStatus.Completed)
        .OrderByDescending(b => b.CompletedAt)
        .ToList() ?? new List<Booking>();
    var reviews = Model.ReviewsReceived?
        .OrderByDescending(r => r.CreatedAt)
        .ToList() ?? new List<Review>();
}

@if (isHidden)
{
    <div class="empty-state">
        <i class="fas fa-user-slash"></i>
        <h5>Profile Unavailable</h5>
        <p>This provider's profile is currently unavailable.</p>
        <a asp-area="Customer" asp-controller="ServiceRequest" asp-action="Index" class="btn btn-primary">
            Back to My Requests
        </a>
    </div>
}
else
{
    <div class="marketplace-page">
        <section class="kh-page-hero">
            <div class="kh-profile-hero">
                <div>
                    @if (!string.IsNullOrEmpty(Model.ProfileImage))
                    {
                        <img src="@Model.ProfileImage" class="kh-profile-avatar"
                             alt="@Model.User?.FirstName @Model.User?.LastName" />
                    }
                    else
                    {
                        <span class="kh-profile-avatar-fallback">
                            @(Model.User?.FirstName?.Substring(0, 1) ?? "P")
                        </span>
                    }
                </div>
                <div>
                    <div class="kh-hero-kicker">
                        <i class="fas fa-user-check"></i>
                        Provider profile
                    </div>
                    <h1 class="kh-page-title">@Model.User?.FirstName @Model.User?.LastName</h1>
                    <p class="kh-page-copy">
                        @(string.IsNullOrWhiteSpace(Model.Bio) ? "A Khidmati provider ready to support local service requests." : Model.Bio)
                    </p>
                    <div class="kh-hero-actions">
                        @if (Model.IsVerified)
                        {
                            <span class="kh-status-badge kh-status-soft-success">
                                <i class="fas fa-shield-alt"></i>Verified provider
                            </span>
                        }
                        <span class="kh-status-badge kh-status-soft-blue">
                            <i class="fas fa-star"></i>@Model.AverageRating.ToString("0.0") rating
                        </span>
                    </div>
                </div>
                <div class="kh-hero-panel">
                    <div class="kh-stat-label">Availability</div>
                    <div class="fs-5 fw-800">
                        @Model.AvailableFrom.ToString(@"hh\:mm") - @Model.AvailableTo.ToString(@"hh\:mm")
                    </div>
                    <div class="small text-white-50 mt-2">@Model.YearsOfExperience years of experience</div>
                </div>
            </div>
        </section>

        <section class="kh-metric-grid">
            <article class="kh-metric">
                <span class="kh-metric-icon"><i class="fas fa-star"></i></span>
                <div class="kh-metric-number">@Model.AverageRating.ToString("0.0")</div>
                <div class="kh-metric-label">Average rating</div>
            </article>
            <article class="kh-metric">
                <span class="kh-metric-icon"><i class="fas fa-briefcase"></i></span>
                <div class="kh-metric-number">@Model.CompletedJobsCount</div>
                <div class="kh-metric-label">Completed jobs</div>
            </article>
            <article class="kh-metric">
                <span class="kh-metric-icon"><i class="fas fa-tags"></i></span>
                <div class="kh-metric-number">@categories.Count()</div>
                <div class="kh-metric-label">Service categories</div>
            </article>
            <article class="kh-metric">
                <span class="kh-metric-icon"><i class="fas fa-message"></i></span>
                <div class="kh-metric-number">@reviews.Count</div>
                <div class="kh-metric-label">Reviews</div>
            </article>
        </section>

        <div class="kh-detail-layout">
            <div class="kh-detail-stack">
                <section class="kh-info-card">
                    <h2 class="h5 mb-3"><i class="fas fa-screwdriver-wrench text-primary me-2"></i>Skills and services</h2>
                    @if (categories.Any())
                    {
                        <div class="kh-skill-list">
                            @foreach (var pc in categories)
                            {
                                <span class="kh-skill-pill">
                                    <i class="fas fa-check"></i>@pc.Category?.Name
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No categories listed yet.</p>
                    }
                </section>

                <section class="kh-info-card">
                    <h2 class="h5 mb-3"><i class="fas fa-circle-info text-primary me-2"></i>Provider summary</h2>
                    <div class="kh-info-row">
                        <span class="kh-info-icon"><i class="fas fa-clock"></i></span>
                        <div>
                            <div class="small text-muted">Availability</div>
                            <div class="fw-800">@Model.AvailableFrom.ToString(@"hh\:mm") - @Model.AvailableTo.ToString(@"hh\:mm")</div>
                        </div>
                    </div>
                    <div class="kh-info-row">
                        <span class="kh-info-icon"><i class="fas fa-award"></i></span>
                        <div>
                            <div class="small text-muted">Experience</div>
                            <div class="fw-800">@Model.YearsOfExperience years</div>
                        </div>
                    </div>
                    <div class="kh-info-row">
                        <span class="kh-info-icon"><i class="fas fa-shield-alt"></i></span>
                        <div>
                            <div class="small text-muted">Verification</div>
                            <div class="fw-800">@(Model.IsVerified ? "Verified" : "Not verified yet")</div>
                        </div>
                    </div>
                </section>
            </div>

            <div class="kh-detail-stack">
                <section class="kh-info-card">
                    <div class="kh-section-head">
                        <div>
                            <h2 class="kh-section-title">Completed jobs</h2>
                            <p class="kh-section-copy">Recent finished work from this provider.</p>
                        </div>
                        <span class="kh-status-badge kh-status-soft-success">
                            <i class="fas fa-check-double"></i>@Model.CompletedJobsCount total
                        </span>
                    </div>

                    @if (completedBookings.Any())
                    {
                        <div class="kh-job-list">
                            @foreach (var b in completedBookings.Take(6))
                            {
                                <div class="kh-job-row">
                                    <div class="kh-inline-between">
                                        <div>
                                            <div class="fw-800">@b.ServiceRequest?.Title</div>
                                            <div class="text-muted small">
                                                <i class="fas fa-tag me-1 text-primary"></i>@b.ServiceRequest?.Category?.Name
                                            </div>
                                        </div>
                                        <span class="text-muted small">@b.CompletedAt?.ToString("MMM dd, yyyy")</span>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-briefcase"></i>
                            <h5>No completed jobs yet</h5>
                            <p>Completed work will appear here after customer confirmation.</p>
                        </div>
                    }
                </section>

                <section class="kh-info-card">
                    <div class="kh-section-head">
                        <div>
                            <h2 class="kh-section-title">Reviews</h2>
                            <p class="kh-section-copy">Customer feedback from completed services.</p>
                        </div>
                    </div>

                    @if (reviews.Any())
                    {
                        <div class="kh-review-list">
                            @foreach (var r in reviews.Take(6))
                            {
                                <div class="kh-review-row">
                                    <div class="kh-inline-between mb-2">
                                        <div>
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="fas fa-star @(i <= r.Rating ? "text-warning" : "text-muted")"></i>
                                            }
                                            <span class="ms-2 small fw-800">
                                                @r.Customer?.FirstName @r.Customer?.LastName
                                            </span>
                                        </div>
                                        <span class="text-muted small">@r.CreatedAt.ToString("MMM dd, yyyy")</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(r.Comment))
                                    {
                                        <p class="text-muted mb-0">@r.Comment</p>
                                    }
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state">
                            <i class="fas fa-star"></i>
                            <h5>No reviews yet</h5>
                            <p>Reviews will appear after completed bookings.</p>
                        </div>
                    }
                </section>
            </div>
        </div>
    </div>
}
